<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academic Analysis System</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: #8b5cf6;
            --accent: #ec4899;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --dark: #0f172a;
            --dark-light: #1e293b;
            --dark-lighter: #334155;
            --text: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: var(--text);
            overflow: hidden;
            line-height: 1.6;
        }
        
        .app-container {
            display: flex;
            height: 100vh;
            position: relative;
        }
        
        /* SIDEBAR */
        .sidebar {
            width: 300px;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 100;
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.3);
        }
        
        .logo-section {
            padding: 32px 24px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.05) 100%);
        }
        
        .logo {
            width: 64px;
            height: 64px;
            margin: 0 auto 16px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3);
        }
        
        .logo-section h1 {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }
        
        .logo-section p {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
        }
        
        .menu {
            flex: 1;
            padding: 24px 0;
            overflow-y: auto;
        }
        
        .menu::-webkit-scrollbar {
            width: 6px;
        }
        
        .menu::-webkit-scrollbar-track {
            background: transparent;
        }
        
        .menu::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }
        
        .menu-item {
            padding: 14px 24px;
            margin: 4px 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 14px;
            position: relative;
            overflow: hidden;
        }
        
        .menu-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 3px;
            background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
            transform: scaleY(0);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .menu-item:hover {
            background: rgba(99, 102, 241, 0.1);
            transform: translateX(4px);
        }
        
        .menu-item.active {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(139, 92, 246, 0.1) 100%);
            color: var(--primary-light);
        }
        
        .menu-item.active::before {
            transform: scaleY(1);
        }
        
        .menu-icon {
            font-size: 20px;
            width: 24px;
            text-align: center;
            filter: drop-shadow(0 0 8px currentColor);
        }
        
        .menu-text {
            font-weight: 500;
            font-size: 14px;
        }
        
        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }
        
        .header {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(15, 23, 42, 0.95) 100%);
            backdrop-filter: blur(10px);
            padding: 28px 40px;
            border-bottom: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
        }
        
        .header h2 {
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .content-area {
            flex: 1;
            padding: 32px 40px;
            overflow-y: auto;
            position: relative;
        }
        
        .content-area::-webkit-scrollbar {
            width: 10px;
        }
        
        .content-area::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.5);
            border-radius: 5px;
        }
        
        .content-area::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
            border-radius: 5px;
        }
        
        .section {
            display: none;
        }
        
        .section.active {
            display: block;
            animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* CARDS */
        .card {
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 28px;
            margin-bottom: 28px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .card:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 32px rgba(99, 102, 241, 0.2);
            transform: translateY(-2px);
        }
        
        .card h3 {
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 20px;
            font-size: 20px;
            font-weight: 700;
        }
        
        /* FORM ELEMENTS */
        .form-group {
            margin-bottom: 24px;
        }
        
        label {
            display: block;
            margin-bottom: 10px;
            color: var(--text);
            font-weight: 600;
            font-size: 14px;
        }
        
        input[type="text"],
        input[type="password"],
        input[type="number"],
        input[type="email"] {
            width: 100%;
            padding: 14px 16px;
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 15px;
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        input:focus {
            outline: none;
            border-color: var(--primary);
            background: rgba(15, 23, 42, 0.95);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }
        
        input::placeholder {
            color: var(--text-muted);
        }
        
        /* CHECKBOX LABEL */
        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            padding: 14px 16px;
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--border);
            border-radius: 10px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .checkbox-label:hover {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.05);
        }
        
        .checkbox-label input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: var(--primary);
        }
        
        .checkbox-label span {
            color: var(--text);
            font-weight: 500;
            font-size: 14px;
        }
        
        /* BUTTONS */
        .btn {
            padding: 14px 28px;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }
        
        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        
        .btn-secondary {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }
        
        .btn-secondary:hover {
            background: rgba(99, 102, 241, 0.1);
            border-color: var(--primary-light);
            color: var(--primary-light);
        }
        
        /* DATABASE SELECTION */
        .db-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin: 24px 0;
        }
        
        .db-card {
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--border);
            border-radius: 14px;
            padding: 24px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .db-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .db-card:hover::before {
            opacity: 1;
        }
        
        .db-card:hover {
            border-color: var(--primary);
            transform: translateY(-8px);
            box-shadow: 0 12px 32px rgba(99, 102, 241, 0.3);
        }
        
        .db-card.selected {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(139, 92, 246, 0.1) 100%);
            box-shadow: 0 8px 24px rgba(99, 102, 241, 0.2);
        }
        
        .db-card input[type="checkbox"] {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 22px;
            height: 22px;
            cursor: pointer;
            accent-color: var(--primary);
        }
        
        .db-logo {
            width: 100px;
            height: 100px;
            margin-bottom: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            filter: brightness(0.9) grayscale(0.15);
            transition: transform 0.3s, filter 0.3s;
        }

        .db-logo svg {
            width: 100%;
            height: 100%;
        }

        .db-card:hover .db-logo,
        .db-card.selected .db-logo {
            filter: brightness(1.15) grayscale(0);
            transform: scale(1.05);
        }

        /* Colores por base */
        .db-icon-ebsco { color: var(--primary); }
        .db-icon-ieee { color: #0ea5e9; }
        
        .db-name {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }
        
        .db-count {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 14px;
            font-weight: 600;
        }
        
        /* RADIO BUTTONS */
        .radio-group {
            display: flex;
            gap: 20px;
            margin: 16px 0;
            flex-wrap: wrap;
        }
        
        .radio-option {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }
        
        .radio-option input[type="radio"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: var(--primary);
        }
        
        /* PROGRESS BAR */
        .progress-container {
            margin: 32px 0;
            display: none;
        }
        
        .progress-container.active {
            display: block;
            animation: fadeIn 0.5s;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        .progress-bar {
            width: 100%;
            height: 48px;
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--border);
            border-radius: 24px;
            overflow: hidden;
            position: relative;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary) 0%, var(--secondary) 50%, var(--accent) 100%);
            background-size: 200% 100%;
            animation: shimmer 2s infinite;
            transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 0 24px rgba(99, 102, 241, 0.5);
            position: relative;
            overflow: hidden;
        }
        
        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        .status-message {
            text-align: center;
            margin-top: 16px;
            font-size: 16px;
            font-weight: 600;
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .substatus {
            text-align: center;
            margin-top: 8px;
            font-size: 14px;
            color: var(--text-muted);
        }
        
        /* RESULTS */
        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 24px 0;
        }
        
        .stat-card {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.05) 100%);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
            text-align: center;
            transition: all 0.3s;
        }
        
        .stat-card:hover {
            border-color: var(--primary);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(99, 102, 241, 0.2);
        }
        
        .stat-label {
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }
        
        .stat-value {
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 36px;
            font-weight: 800;
        }
        
        .algorithm-list {
            list-style: none;
        }
        
        .algorithm-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 10px;
            margin-bottom: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .algorithm-item:hover {
            border-color: var(--primary);
            transform: translateX(8px);
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.2);
        }
        
        .algorithm-rank {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: 4px 12px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 14px;
            min-width: 40px;
            text-align: center;
        }
        
        .algorithm-name {
            flex: 1;
            font-weight: 600;
            margin: 0 16px;
            font-size: 15px;
        }
        
        .algorithm-time {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
            font-size: 15px;
        }
        
        .chart-container {
            background: white;
            border-radius: 14px;
            padding: 24px;
            margin: 24px 0;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
        }
        
        .chart-container img {
            width: 100%;
            height: auto;
            border-radius: 10px;
        }

        /* Tooltips accesibles */
        .tooltip {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: help;
        }
        .info-icon {
            width: 18px; height: 18px; line-height: 18px;
            margin-left: 6px; border-radius: 50%;
            background: rgba(99,102,241,0.18);
            color: var(--primary);
            -webkit-text-fill-color: var(--primary); /* corrige icono invisible si el padre usa text-fill transparente */
            font-size: 12px; font-weight: 700;
            text-align: center;
            user-select: none;
        }
        .tooltip:focus::after, .tooltip:hover::after {
            content: attr(data-tip);
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%; transform: translateX(-50%);
            background: rgba(15,23,42,0.95);
            color: #e5e7eb; 
            -webkit-text-fill-color: #e5e7eb; /* evita heredar texto transparente de encabezados con gradient */
            border: 1px solid var(--border);
            padding: 8px 10px; border-radius: 8px;
            white-space: normal; width: max-content; max-width: 320px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.35);
            z-index: 2000; font-size: 12px; font-weight: 500;
            display: block; pointer-events: none;
        }
        .tooltip:focus::before, .tooltip:hover::before {
            content: '';
            position: absolute;
            bottom: calc(100%);
            left: 50%; transform: translateX(-50%);
            border-width: 6px; border-style: solid;
            border-color: rgba(15,23,42,0.95) transparent transparent transparent;
            z-index: 2001; pointer-events: none;
        }
        
        /* FILE BUTTONS */
        .file-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin: 24px 0;
        }
        
        .file-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 24px;
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--primary);
            border-radius: 10px;
            color: var(--primary);
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .file-btn:hover {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(139, 92, 246, 0.15) 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
        }
        
        /* LOG CONSOLE */
        .log-box {
            height: 240px;
            background: rgba(10, 10, 10, 0.9);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 16px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #10b981;
            overflow-y: auto;
            white-space: pre-wrap;
            line-height: 1.5;
            box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.5);
        }
        
        .log-box::-webkit-scrollbar {
            width: 8px;
        }
        
        .log-box::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 4px;
        }
        
        /* ALERTS */
        .alert {
            padding: 16px 20px;
            border-radius: 10px;
            margin: 20px 0;
            border-left: 4px solid;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .alert-warning {
            background: rgba(245, 158, 11, 0.1);
            border-color: var(--warning);
            color: var(--warning);
        }
        
        .alert-info {
            background: rgba(99, 102, 241, 0.1);
            border-color: var(--primary);
            color: var(--primary-light);
        }
        
        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            border-color: var(--success);
            color: var(--success);
        }
        
        /* UTILITIES */
        .hidden {
            display: none !important;
        }
        
        .text-center {
            text-align: center;
        }
        
        .mb-20 {
            margin-bottom: 20px;
        }
        
        .mt-20 {
            margin-top: 20px;
        }
        
        /* Decorative elements */
        .bg-decoration {
            position: fixed;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.1;
            pointer-events: none;
            z-index: 0;
        }
        
        .bg-decoration-1 {
            background: var(--primary);
            top: -200px;
            right: -200px;
        }
        
        .bg-decoration-2 {
            background: var(--secondary);
            bottom: -200px;
            left: -200px;
        }
    </style>
</head>
<body>
    <div class="bg-decoration bg-decoration-1"></div>
    <div class="bg-decoration bg-decoration-2"></div>
    
    <div class="app-container">
        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="logo-section">
                <div class="logo">🎓</div>
                <h1>AAS</h1>
                <p>Academic Analysis System</p>
            </div>
            
            <div class="menu">
                <div class="menu-item active" onclick="showSection('dashboard')">
                    <span class="menu-icon">🏠</span>
                    <span class="menu-text">Dashboard</span>
                </div>
                <div class="menu-item" onclick="showSection('pipeline')">
                    <span class="menu-icon">🔄</span>
                    <span class="menu-text">Pipeline Completo</span>
                </div>
                <div class="menu-item" onclick="showSection('scraping')">
                    <span class="menu-icon">🔍</span>
                    <span class="menu-text">Solo Scraping</span>
                </div>
                <div class="menu-item" onclick="showSection('cleaning')">
                    <span class="menu-icon">🧹</span>
                    <span class="menu-text">Solo Limpieza</span>
                </div>
                <div class="menu-item" onclick="showSection('analysis')">
                    <span class="menu-icon">📊</span>
                    <span class="menu-text">Solo Algoritmos</span>
                </div>
            </div>
        </div>
        
        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="header">
                <h2 id="section-title">Dashboard Principal</h2>
            </div>
            
            <div class="content-area">
                <!-- DASHBOARD -->
                <div id="dashboard" class="section active">
                    <div class="card">
                        <h3>👋 Bienvenido al Sistema de Análisis Académico</h3>
                        <p style="color: var(--text-muted); line-height: 1.8; font-size: 15px;">
                            Este sistema te permite realizar scraping de múltiples bases de datos académicas,
                            limpiar y unificar los datos, y analizar el rendimiento de diferentes algoritmos
                            de ordenamiento.
                        </p>
                        
                        <div class="results-grid mt-20">
                            <div class="stat-card">
                                <div class="stat-label">Bases de Datos</div>
                                <div class="stat-value">2</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Algoritmos</div>
                                <div class="stat-value">12</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Formato</div>
                                <div class="stat-value">CSV</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card">
                        <h3>🚀 Inicio Rápido</h3>
                        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 15px;">
                            Selecciona una opción para comenzar:
                        </p>
                        
                        <div class="file-buttons">
                            <button class="btn btn-primary" onclick="showSection('pipeline')">
                                🔄 Pipeline Completo
                            </button>
                            <button class="btn btn-secondary" onclick="showSection('scraping')">
                                🔍 Solo Scraping
                            </button>
                            <button class="btn btn-secondary" onclick="showSection('cleaning')">
                                🧹 Solo Limpieza
                            </button>
                            <button class="btn btn-secondary" onclick="showSection('analysis')">
                                📊 Solo Algoritmos
                            </button>
                        </div>
                    </div>
                    
                    <div class="card">
                        <h3>🧭 Consola en vivo</h3>
                        <div id="global-log" class="log-box"></div>
                    </div>
                </div>
                
                <!-- PIPELINE COMPLETO -->
                <div id="pipeline" class="section">
                    <div class="card">
                        <h3>🔄 Pipeline Completo</h3>
                        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 15px;">
                            Ejecuta todo el proceso: Scraping → Limpieza → Análisis
                        </p>
                        
                        <div id="login-section">
                            <div class="form-group">
                                <label>📧 Email / Usuario:</label>
                                <input type="email" id="pipeline-email" placeholder="tu@email.com">
                            </div>
                            
                            <div class="form-group">
                                <label>🔒 Contraseña:</label>
                                <input type="password" id="pipeline-password" placeholder="••••••••">
                            </div>
                            
                            <div class="form-group">
                                <label class="checkbox-label">
                                    <input type="checkbox" id="pipeline-show-browser" checked>
                                    <span>🌐 Mostrar navegador durante el login (recomendado para 2FA)</span>
                                </label>
                            </div>
                            
                            <div class="alert alert-info">
                                <span>ℹ️</span>
                                <span>Las mismas credenciales se usarán para todas las bases de datos seleccionadas.
                                Espera aprox. 60 segundos por la autenticación 2FA de Google.</span>
                            </div>
                        </div>
                        
                        <div class="form-group mt-20">
                            <label>🔎 Término de búsqueda:</label>
                            <input type="text" id="pipeline-query" placeholder="Ej: artificial intelligence" value="artificial intelligence">
                        </div>
                        
                        <button class="btn btn-secondary mb-20" onclick="checkAvailability('pipeline')">
                            🔍 Verificar disponibilidad
                        </button>
                        
                        <label>Selecciona bases de datos (mínimo 2):</label>
                        <div class="db-grid" id="pipeline-db-grid">
                            <div class="db-card" onclick="toggleDB('pipeline', 'ebsco')">
                                <input type="checkbox" id="pipeline-db-ebsco">
                                <div class="db-logo db-icon-ebsco" aria-label="EBSCO" role="img">
                                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <rect x="12" y="12" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <rect x="12" y="26" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <rect x="12" y="40" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                    </svg>
                                </div>
                                <div class="db-name">EBSCO</div>
                                <div class="db-count" id="pipeline-count-ebsco">- resultados</div>
                            </div>
                            
                            <div class="db-card" onclick="toggleDB('pipeline', 'ieee')">
                                <input type="checkbox" id="pipeline-db-ieee">
                                <div class="db-logo db-icon-ieee" aria-label="IEEE Xplore" role="img">
                                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <rect x="16" y="16" width="32" height="32" rx="5" ry="5" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <!-- pins top -->
                                        <line x1="20" y1="12" x2="20" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="28" y1="12" x2="28" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="36" y1="12" x2="36" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="44" y1="12" x2="44" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <!-- pins bottom -->
                                        <line x1="20" y1="48" x2="20" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="28" y1="48" x2="28" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="36" y1="48" x2="36" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="44" y1="48" x2="44" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <!-- pins left -->
                                        <line x1="12" y1="20" x2="16" y2="20" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="28" x2="16" y2="28" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="36" x2="16" y2="36" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="44" x2="16" y2="44" stroke="currentColor" stroke-width="3"/>
                                        <!-- pins right -->
                                        <line x1="48" y1="20" x2="52" y2="20" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="28" x2="52" y2="28" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="36" x2="52" y2="36" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="44" x2="52" y2="44" stroke="currentColor" stroke-width="3"/>
                                    </svg>
                                </div>
                                <div class="db-name">IEEE Xplore</div>
                                <div class="db-count" id="pipeline-count-ieee">- resultados</div>
                            </div>
                            
                            
                        </div>
                        
                        <div class="form-group mt-20">
                            <label>Cantidad a descargar:</label>
                            <div class="radio-group">
                                <label class="radio-option">
                                    <input type="radio" name="pipeline-amount" value="all" checked>
                                    <span>Descargar todo</span>
                                </label>
                                <label class="radio-option">
                                    <input type="radio" name="pipeline-amount" value="custom">
                                    <span>Cantidad personalizada:</span>
                                </label>
                                <input type="number" id="pipeline-custom-amount" value="100" min="1" style="width: 120px;">
                            </div>
                        </div>

                        <div class="form-group mt-20">
                            <label>🧠 Similitud Textual en el Pipeline</label>
                            <label class="checkbox-label"><input type="checkbox" id="pipeline-sim-enable"> <span>Incluir análisis de similitud textual al finalizar</span></label>
                            <div id="pipeline-sim-opts" style="margin-left:22px; margin-top:8px; display:block;">
                                <div style="display:flex; gap:20px; flex-wrap:wrap;">
                                    <label class="checkbox-label"><input type="checkbox" id="pipe-only-abs" checked> <span>Solo artículos con abstract</span></label>
                                    <label class="checkbox-label"><span>Límite:</span> <input type="number" id="pipeline-sim-limit" value="50" min="2" style="width: 100px; margin-left:8px;"></label>
                                </div>
                                <div style="margin-top:10px;">
                                    <label class="checkbox-label"><input type="checkbox" id="pipe-use-classic" checked> <span>Clásicos</span></label>
                                    <div style="margin:6px 0 10px 22px; display:grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap:6px;">
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-lev" checked> <span>Levenshtein</span></label>
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-jaro" checked> <span>Jaro-Winkler</span></label>
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-tfidf" checked> <span>TF-IDF</span></label>
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-cos" checked> <span>Coseno</span></label>
                                    </div>
                                    <label class="checkbox-label"><input type="checkbox" id="pipe-use-ai" checked> <span>IA</span></label>
                                    <div style="margin:6px 0 0 22px; display:grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap:6px;">
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-sbert" checked> <span>SBERT</span></label>
                                        <label class="checkbox-label"><input type="checkbox" id="pipe-hf" checked> <span>HF-MeanPooling</span></label>
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info" style="margin-top:8px;">
                                <span>ℹ️</span>
                                <span>El análisis de similitud es O(n²) sobre el límite de artículos; ajusta el límite según el tamaño del dataset.</span>
                            </div>
                        </div>
                        
                        <button class="btn btn-primary" onclick="startFullPipeline()">
                            🚀 Iniciar Pipeline Completo
                        </button>
                        
                        <div class="progress-container" id="pipeline-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="pipeline-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="pipeline-status">Esperando...</div>
                            <div class="substatus" id="pipeline-substatus"></div>
                        </div>
                        
                        <div id="pipeline-results" class="hidden mt-20">
                            <h3 style="background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                                🎉 Resultados
                            </h3>
                            
                            <div class="chart-container" id="pipeline-chart">
                                <img id="pipeline-chart-img" src="" alt="Gráfico de comparación">
                            </div>
                            
                            <div class="card">
                                <h3>⏱️ Tiempos de Ejecución</h3>
                                <ul class="algorithm-list" id="pipeline-algorithm-list"></ul>
                            </div>
                            
                            <div class="file-buttons">
                                <button class="file-btn" onclick="openFile('sorted')">
                                    📄 Abrir CSV Ordenado
                                </button>
                                <button class="file-btn" onclick="openFile('unified')">
                                    📄 Abrir CSV Unificado
                                </button>
                                <button class="file-btn" onclick="openFile('chart')">
                                    📊 Abrir Gráfico
                                </button>
                                <button class="file-btn" onclick="openFile('authors')">
                                    👥 Top Autores
                                </button>
                                <button class="file-btn" onclick="openFile('citation_graph')">
                                    🔗 Grafo Citaciones (PNG)
                                </button>
                                <button class="file-btn" onclick="openFile('cooc_graph')">
                                    📎 Grafo Coocurrencias (PNG)
                                </button>
                            </div>

                            <div class="card" id="pipeline-sim-card" style="margin-top:16px;">
                                <h3>🧠 Resultados de Similitud (Pipeline)</h3>
                                <div id="pipeline-sim-results"></div>
                            </div>
                            <div class="card" id="pipeline-concepts-card" style="margin-top:16px;">
                                <h3>🧩 Resultados de Conceptos (GAIE)</h3>
                                <div id="pipeline-concepts-results"></div>
                            </div>
                            <div class="card" id="pipeline-hc-card" style="margin-top:16px;">
                                <h3>🌳 Dendrogramas (Clustering Jerárquico)</h3>
                                <div id="pipeline-hc-results"></div>
                            </div>

                            <div class="card" id="pipeline-citation-card" style="margin-top:16px;">
                                <h3>🔗 Red de Citaciones (Pipeline)</h3>
                                <div class="results-grid">
                                    <div class="stat-card"><div class="stat-label">Nodos</div><div class="stat-value" id="pl-cn-nodes">-</div></div>
                                    <div class="stat-card"><div class="stat-label">Aristas</div><div class="stat-value" id="pl-cn-edges">-</div></div>
                                    <div class="stat-card"><div class="stat-label">SCC</div><div class="stat-value" id="pl-cn-scc">-</div></div>
                                </div>
                                <div class="chart-container" style="background: rgba(255,255,255,0.02); overflow:hidden;">
                                    <canvas id="pipeline-citation-canvas" style="width:100%; height:auto; display:block; background: rgba(15,23,42,0.6); border-radius: 12px;"></canvas>
                                </div>
                                <div class="form-group">
                                    <label>🧭 Camino mínimo (Dijkstra)</label>
                                    <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                                        <select id="pl-cn-source" style="min-width:260px;"></select>
                                        <span style="color: var(--text-muted)">→</span>
                                        <select id="pl-cn-target" style="min-width:260px;"></select>
                                        <button class="btn" onclick="computePipelineCitationShortestPath()">Calcular</button>
                                    </div>
                                    <div id="pl-cn-path-result" style="margin-top:8px; color: var(--text-muted);"></div>
                                </div>
                                <div class="form-group">
                                    <label>🧩 Componentes fuertemente conexas</label>
                                    <div id="pl-cn-scc-list" class="log-box" style="height: 160px; overflow:auto;"></div>
                                </div>
                                <div class="form-group">
                                    <label>🏁 Top 10 caminos mínimos (Dijkstra)</label>
                                    <div id="pl-cn-top-paths" class="log-box" style="height: 160px; overflow:auto;"></div>
                                </div>
                                <div class="form-group">
                                    <label>🧩 SCC más grandes</label>
                                    <div id="pl-cn-top-sccs" class="log-box" style="height: 140px; overflow:auto;"></div>
                                </div>
                            </div>

                            <div class="card" id="pipeline-cooc-card" style="margin-top:16px;">
                                <h3>🧩 Grafo de Coocurrencia de Términos (Pipeline)</h3>
                                <div class="results-grid">
                                    <div class="stat-card"><div class="stat-label">Términos</div><div class="stat-value" id="pl-co-nodes">-</div></div>
                                    <div class="stat-card"><div class="stat-label">Aristas</div><div class="stat-value" id="pl-co-edges">-</div></div>
                                    <div class="stat-card"><div class="stat-label">Componentes</div><div class="stat-value" id="pl-co-comps">-</div></div>
                                </div>
                                <div class="chart-container" style="background: rgba(255,255,255,0.02); overflow:hidden;">
                                    <img id="pipeline-cooc-img" src="" alt="Grafo de coocurrencia" style="width:100%; height:auto; display:block; background: rgba(15,23,42,0.6); border-radius: 12px;" />
                                </div>
                                <div class="form-group">
                                    <label>📈 Top grados (términos más conectados)</label>
                                    <div id="pl-co-degrees" class="log-box" style="height: 160px; overflow:auto;"></div>
                                </div>
                                <div class="form-group">
                                    <label>🔗 Componentes conexas</label>
                                    <div id="pl-co-components" class="log-box" style="height: 160px; overflow:auto;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- SOLO SCRAPING -->
                <div id="scraping" class="section">
                    <div class="card">
                        <h3>🔍 Solo Scraping</h3>
                        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 15px;">
                            Extrae artículos de las bases de datos académicas
                        </p>
                        
                        <div class="form-group">
                            <label>📧 Email / Usuario:</label>
                            <input type="email" id="scraping-email" placeholder="tu@email.com">
                        </div>
                        
                        <div class="form-group">
                            <label>🔒 Contraseña:</label>
                            <input type="password" id="scraping-password" placeholder="••••••••">
                        </div>
                        
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" id="scraping-show-browser" checked>
                                <span>🌐 Mostrar navegador durante el login</span>
                            </label>
                        </div>
                        
                        <div class="form-group mt-20">
                            <label>🔎 Término de búsqueda:</label>
                            <input type="text" id="scraping-query" placeholder="Ej: machine learning" value="machine learning">
                        </div>
                        
                        <button class="btn btn-secondary mb-20" onclick="checkAvailability('scraping')">
                            🔍 Verificar disponibilidad
                        </button>
                        
                        <label>Selecciona bases de datos (mínimo 2):</label>
                        <div class="db-grid">
                            <div class="db-card" onclick="toggleDB('scraping', 'ebsco')">
                                <input type="checkbox" id="scraping-db-ebsco">
                                <div class="db-logo db-icon-ebsco" aria-label="EBSCO" role="img">
                                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <rect x="12" y="12" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <rect x="12" y="26" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <rect x="12" y="40" width="40" height="10" rx="3" ry="3" stroke="currentColor" fill="none" stroke-width="3"/>
                                    </svg>
                                </div>
                                <div class="db-name">EBSCO</div>
                                <div class="db-count" id="scraping-count-ebsco">- resultados</div>
                            </div>
                            
                            <div class="db-card" onclick="toggleDB('scraping', 'ieee')">
                                <input type="checkbox" id="scraping-db-ieee">
                                <div class="db-logo db-icon-ieee" aria-label="IEEE Xplore" role="img">
                                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <rect x="16" y="16" width="32" height="32" rx="5" ry="5" stroke="currentColor" fill="none" stroke-width="3"/>
                                        <line x1="20" y1="12" x2="20" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="28" y1="12" x2="28" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="36" y1="12" x2="36" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="44" y1="12" x2="44" y2="16" stroke="currentColor" stroke-width="3"/>
                                        <line x1="20" y1="48" x2="20" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="28" y1="48" x2="28" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="36" y1="48" x2="36" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="44" y1="48" x2="44" y2="52" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="20" x2="16" y2="20" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="28" x2="16" y2="28" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="36" x2="16" y2="36" stroke="currentColor" stroke-width="3"/>
                                        <line x1="12" y1="44" x2="16" y2="44" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="20" x2="52" y2="20" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="28" x2="52" y2="28" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="36" x2="52" y2="36" stroke="currentColor" stroke-width="3"/>
                                        <line x1="48" y1="44" x2="52" y2="44" stroke="currentColor" stroke-width="3"/>
                                    </svg>
                                </div>
                                <div class="db-name">IEEE Xplore</div>
                                <div class="db-count" id="scraping-count-ieee">- resultados</div>
                            </div>
                            
                            
                        </div>
                        
                        <div class="form-group mt-20">
                            <label>Cantidad a descargar:</label>
                            <div class="radio-group">
                                <label class="radio-option">
                                    <input type="radio" name="scraping-amount" value="all" checked>
                                    <span>Descargar todo</span>
                                </label>
                                <label class="radio-option">
                                    <input type="radio" name="scraping-amount" value="custom">
                                    <span>Cantidad personalizada:</span>
                                </label>
                                <input type="number" id="scraping-custom-amount" value="100" min="1" style="width: 120px;">
                            </div>
                        </div>
                        
                        <button class="btn btn-primary" onclick="startScraping()">
                            🚀 Iniciar Scraping
                        </button>
                        
                        <div class="progress-container" id="scraping-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="scraping-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="scraping-status">Esperando...</div>
                            <div class="substatus" id="scraping-substatus"></div>
                        </div>
                    </div>
                </div>
                
                <!-- SOLO LIMPIEZA -->
                <div id="cleaning" class="section">
                    <div class="card">
                        <h3>🧹 Solo Limpieza</h3>
                        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 15px;">
                            Limpia y unifica archivos CSV existentes
                        </p>
                        
                        <div class="alert alert-info mb-20">
                            <span>ℹ️</span>
                            <span>Selecciona al menos 2 archivos CSV para limpiar y unificar</span>
                        </div>
                        
                        <div class="form-group">
                            <label>📁 Archivo EBSCO (opcional):</label>
                            <button class="btn btn-secondary" onclick="selectFile('cleaning-ebsco')">
                                Seleccionar CSV
                            </button>
                            <span id="cleaning-ebsco-file" style="color: var(--text-muted); margin-left: 15px;">Ninguno seleccionado</span>
                        </div>
                        
                        <div class="form-group">
                            <label>📁 Archivo IEEE (opcional):</label>
                            <button class="btn btn-secondary" onclick="selectFile('cleaning-ieee')">
                                Seleccionar CSV
                            </button>
                            <span id="cleaning-ieee-file" style="color: var(--text-muted); margin-left: 15px;">Ninguno seleccionado</span>
                        </div>
                        
                        
                        
                        <button class="btn btn-primary" onclick="startCleaning()">
                            🧹 Iniciar Limpieza
                        </button>
                        
                        <div class="progress-container" id="cleaning-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="cleaning-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="cleaning-status">Esperando...</div>
                            <div class="substatus" id="cleaning-substatus"></div>
                        </div>
                        
                        <div id="cleaning-results" class="hidden mt-20">
                            <div class="results-grid">
                                <div class="stat-card">
                                    <div class="stat-label">Registros Únicos</div>
                                    <div class="stat-value" id="cleaning-total">-</div>
                                </div>
                            </div>
                            
                            <div class="file-buttons">
                                <button class="file-btn" onclick="openFile('unified')">
                                    📄 Abrir CSV Unificado
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- SOLO ALGORITMOS -->
                <div id="analysis" class="section">
                    <div class="card" style="overflow: visible;">
                        <h3>📊 Algoritmo de ordenamiento 
                            <span class="tooltip info-icon" tabindex="0" 
                                aria-label="Organiza los artículos de tu investigación en orden (por ejemplo, del más antiguo al más reciente, o alfabéticamente por título). Probamos 12 formas diferentes de hacerlo y te mostramos cuál es más rápida, junto con un gráfico fácil de entender." 
                                data-tip="Organiza los artículos de tu investigación en orden (por ejemplo, del más antiguo al más reciente, o alfabéticamente por título). Probamos 12 formas diferentes de hacerlo y te mostramos cuál es más rápida, junto con un gráfico fácil de entender.">ⓘ</span>
                        </h3>
                        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 15px;">
                            Analiza un archivo CSV con 12 algoritmos de ordenamiento
                        </p>
                        
                        <div class="form-group">
                            <label>📁 Selecciona archivo CSV a analizar:</label>
                            <button class="btn btn-secondary" onclick="selectFile('analysis-csv')">
                                Seleccionar CSV
                            </button>
                            <span id="analysis-csv-file" style="color: var(--text-muted); margin-left: 15px;">Ninguno seleccionado</span>
                        </div>
                        
                        <button class="btn btn-primary" onclick="startAnalysis()">
                            📊 Iniciar Análisis
                        </button>
                        
                        <div class="progress-container" id="analysis-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="analysis-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="analysis-status">Esperando...</div>
                            <div class="substatus" id="analysis-substatus"></div>
                        </div>
                        
                        <div id="analysis-results" class="hidden mt-20">
                            <h3 style="background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                                🎉 Resultados del Análisis
                            </h3>
                            
                            <div class="chart-container" id="analysis-chart">
                                <img id="analysis-chart-img" src="" alt="Gráfico de comparación">
                            </div>
                            
                            <div class="card">
                                <h3>⏱️ Tiempos de Ejecución</h3>
                                <ul class="algorithm-list" id="analysis-algorithm-list"></ul>
                            </div>
                            
                            <div class="file-buttons">
                                <button class="file-btn" onclick="openFile('sorted')">
                                    📄 Abrir CSV Ordenado
                                </button>
                                <button class="file-btn" onclick="openFile('chart')">
                                    📊 Abrir Gráfico
                                </button>
                                <button class="file-btn" onclick="openFile('authors')">
                                    � Top Autores
                                </button>
                            </div>
                        </div>

                    </div>

                    <!-- NUEVO: Análisis de Conceptos (GAIE) -->
                    <div class="card" style="overflow: visible;">
                        <h3>🧩 Conceptos GAIE (Generative AI in Education) <span class="tooltip info-icon" tabindex="0" aria-label="Lee los resúmenes (abstracts) y detecta los términos y frases más representativos con TF‑IDF. Esto te ayuda a descubrir temas, mejorar tus palabras clave y apoyar la categorización en el dominio de IA generativa en educación." data-tip="Lee los resúmenes (abstracts) y detecta los términos y frases más representativos con TF‑IDF. Esto te ayuda a descubrir temas, mejorar tus palabras clave y apoyar la categorización en el dominio de IA generativa en educación.">ⓘ</span></h3>
                        <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 14px;">
                            Cuenta la frecuencia de términos semilla de la categoría y extrae hasta 15 términos asociados; además estima la precisión de los términos generados.
                        </p>
                        <div class="form-group">
                            <label>📁 Fuente de artículos</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap;">
                                <button class="btn btn-secondary" onclick="selectFile('analysis-csv')">Elegir CSV…</button>
                                <span style="color: var(--text-muted);">Usará el CSV seleccionado para "Solo Análisis de Algoritmos" si está disponible; de lo contrario, el CSV unificado del pipeline.</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="runConceptsAnalysis()">Analizar Conceptos</button>
                        <div class="progress-container" id="concepts-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="concepts-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="concepts-status">Esperando...</div>
                            <div class="substatus" id="concepts-substatus"></div>
                        </div>
                        <div class="mt-20">
                            <h3>📈 Resultados de Conceptos</h3>
                            <div id="concepts-results"></div>
                        </div>
                    </div>

                    <!-- NUEVO: Similitud Textual (selección múltiple) -->
                    <div class="card" style="overflow: visible;">
                        <h3>🌳 Clustering Jerárquico (Dendrogramas) <span class="tooltip info-icon" tabindex="0" aria-label="Agrupa artículos que se parecen entre sí según sus resúmenes. El resultado es un árbol (dendrograma) para ver grupos y subgrupos. Puedes cambiar el criterio (single, complete, average) para ajustar cómo se forman los grupos." data-tip="Agrupa artículos que se parecen entre sí según sus resúmenes. El resultado es un árbol (dendrograma) para ver grupos y subgrupos. Puedes cambiar el criterio (single, complete, average) para ajustar cómo se forman los grupos.">ⓘ</span></h3>
                        <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 14px;">
                            Genera dendrogramas usando enlaces Single, Complete y Average sobre los abstracts.
                        </p>
                        <div class="form-group">
                            <label>📁 Fuente de artículos</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap; align-items:center;">
                                <button class="btn btn-secondary" onclick="selectFile('analysis-csv')">Elegir CSV…</button>
                                <span style="color: var(--text-muted);">Usa el CSV seleccionado o el unificado del pipeline.</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>⚙️ Opciones</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap; align-items:center;">
                                <label class="checkbox-label"><input type="checkbox" id="hc-single" checked> <span>Single</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="hc-complete" checked> <span>Complete</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="hc-average" checked> <span>Average</span></label>
                                <label class="checkbox-label"><span>Máx. docs:</span> <input type="number" id="hc-maxdocs" value="120" min="2" style="width: 100px; margin-left:8px;"></label>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="runClusteringAnalysis()">Generar dendrogramas</button>
                        <div class="progress-container" id="hc-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="hc-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="hc-status">Esperando...</div>
                            <div class="substatus" id="hc-substatus"></div>
                        </div>
                        <div class="mt-20">
                            <h3>🖼️ Resultados de Dendrogramas</h3>
                            <div id="hc-results"></div>
                        </div>
                    </div>
                    <!-- NUEVO: Similitud Textual (selección múltiple) -->
                    <div class="card" style="overflow: visible;">
                        <h3>🧠 Similitud Textual (Abstracts) <span class="tooltip info-icon" tabindex="0" aria-label="Compara el texto de los resúmenes para medir qué tan parecidos son los artículos. Usa métodos clásicos (TF‑IDF y similitudes de cadenas) y de IA (embeddings) y te muestra qué documentos están más relacionados." data-tip="Compara el texto de los resúmenes para medir qué tan parecidos son los artículos. Usa métodos clásicos (TF‑IDF y similitudes de cadenas) y de IA (embeddings) y te muestra qué documentos están más relacionados.">ⓘ</span></h3>
                        <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 14px;">
                            Selecciona 2 o más artículos, extrae sus abstracts y calcula similitud con algoritmos clásicos e IA.
                        </p>

                        <div class="form-group">
                            <label>📁 Fuente de artículos</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap;">
                                <button class="btn btn-secondary" onclick="loadArticlesForAlgorithms()">Usar CSV Unificado</button>
                                <button class="btn" onclick="selectCSVForAlgorithms()">Elegir CSV…</button>
                                <span id="algo-csv-file" style="color: var(--text-muted); margin-left: 8px;">Ninguno</span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>🗂️ Artículos (marca para seleccionar)</label>
                            <div style="display:flex; gap:10px; align-items:center; margin-bottom:8px;">
                                <button class="btn" onclick="selectAllArticles(true)">Seleccionar todo</button>
                                <button class="btn" onclick="selectAllArticles(false)">Limpiar selección</button>
                            </div>
                            <div id="algo-articles-list" class="log-box" style="height: 260px; overflow:auto;"></div>
                        </div>

                        <div class="form-group">
                            <label>⚙️ Algoritmos a usar</label>
                            <label class="checkbox-label"><input type="checkbox" id="algoUseClassic" checked> <span>Clásicos</span></label>
                            <div id="algo-classic-group" style="margin: 6px 0 10px 22px; display:grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap: 6px;">
                                <label class="checkbox-label"><input type="checkbox" id="algoLev" checked> <span>Levenshtein</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="algoJaro" checked> <span>Jaro-Winkler</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="algoTFIDF" checked> <span>TF-IDF</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="algoCos" checked> <span>Coseno</span></label>
                            </div>
                            <label class="checkbox-label"><input type="checkbox" id="algoUseAI" checked> <span>IA</span></label>
                            <div id="algo-ai-group" style="margin: 6px 0 0 22px; display:grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap: 6px;">
                                <label class="checkbox-label"><input type="checkbox" id="algoSBERT" checked> <span>SBERT</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="algoHF" checked> <span>HF-MeanPooling</span></label>
                            </div>
                        </div>

                        <button class="btn btn-primary" onclick="runSimilarityAnalysis()">Calcular similitud</button>
                        <div class="progress-container" id="algo-sim-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="algo-sim-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="algo-sim-status">Esperando...</div>
                            <div class="substatus" id="algo-sim-substatus"></div>
                        </div>
                        <div class="mt-20">
                            <h3>📈 Resultados de Similitud</h3>
                            <div id="algo-results"></div>
                        </div>
                    </div>

                    <!-- NUEVO: Red de Citaciones (Solo Algoritmos) -->
                    <div class="card" style="overflow: visible;">
                        <h3>🔗 Red de Citaciones (Grafo dirigido) <span class="tooltip info-icon" tabindex="0" aria-label="Crea un mapa donde cada artículo es un punto y las citaciones son flechas. Si no hay citaciones explícitas, las deduce por similitud (título, autores y palabras clave). Luego permite ver grupos muy conectados (SCC) y el camino más corto entre dos artículos." data-tip="Crea un mapa donde cada artículo es un punto y las citaciones son flechas. Si no hay citaciones explícitas, las deduce por similitud (título, autores y palabras clave). Luego permite ver grupos muy conectados (SCC) y el camino más corto entre dos artículos.">ⓘ</span></h3>
                        <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 14px;">
                            Construye un grafo dirigido de citaciones; si no hay citaciones explícitas, las infiere por similitud (título/autores/keywords).
                        </p>
                        <div class="form-group">
                            <label>📁 Fuente de artículos</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap; align-items:center;">
                                <button class="btn btn-secondary" onclick="selectFile('analysis-csv')">Elegir CSV…</button>
                                <span style="color: var(--text-muted);">Usa el CSV seleccionado o el unificado/ordenado del pipeline.</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>⚙️ Opciones</label>
                            <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
                                <label class="checkbox-label"><input type="radio" name="cn-backend" value="classic" checked> <span title="Usa TF‑IDF/coseno y comparaciones de texto clásicas; es más simple y suele ser más rápido.">Clásico</span></label>
                                <label class="checkbox-label"><input type="radio" name="cn-backend" value="ia"> <span title="Usa embeddings (SBERT/Transformers) para captar mejor el significado de los textos.">IA</span></label>
                                <label class="checkbox-label"><span title="Valor entre 0 y 1: solo crea flechas si la similitud alcanza este valor. Más alto = menos conexiones.">Umbral:</span> <input type="number" id="cn-threshold" step="0.05" min="0" max="1" value="0.6" style="width:100px; margin-left:8px;"></label>
                                <label class="checkbox-label"><span title="Límite de flechas salientes por artículo al inferir por similitud; evita grafos demasiado densos.">Top-K por nodo:</span> <input type="number" id="cn-topk" min="1" value="3" style="width:100px; margin-left:8px;"></label>
                                <label class="checkbox-label"><input type="checkbox" id="cn-use-concepts"> <span title="Añade términos detectados en resúmenes para mejorar las comparaciones entre artículos.">Enriquecer con conceptos (GAIE)</span></label>
                                <label class="checkbox-label"><span title="Número máximo de artículos a procesar; aumentarlo puede requerir más tiempo y memoria.">Límite:</span> <input type="number" id="cn-limit" min="2" value="120" style="width:100px; margin-left:8px;"></label>
                            </div>
                            <div id="cn-classic-options" style="margin:8px 0 0 0; display:flex; gap:12px; flex-wrap:wrap;">
                                <label class="checkbox-label"><input type="checkbox" id="cn-cl-lev" checked> <span>Levenshtein</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="cn-cl-jw" checked> <span>Jaro-Winkler</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="cn-cl-tfidf" checked> <span>TF‑IDF</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="cn-cl-cos" checked> <span>Coseno</span></label>
                            </div>
                            <div id="cn-ai-options" style="margin:8px 0 0 0; display:none; gap:12px; flex-wrap:wrap;">
                                <label class="checkbox-label"><input type="checkbox" id="cn-ai-sbert" checked> <span>SBERT</span></label>
                                <label class="checkbox-label"><input type="checkbox" id="cn-ai-hf" checked> <span>HF-MeanPooling</span></label>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="runCitationNetworkAnalysis()">Construir red</button>
                        <div class="progress-container" id="citation-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="citation-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="citation-status">Esperando...</div>
                            <div class="substatus" id="citation-substatus"></div>
                        </div>
                        <div class="mt-20">
                            <h3>🖼️ Grafo y métricas de citaciones</h3>
                            <div class="results-grid">
                                <div class="stat-card"><div class="stat-label">Nodos</div><div class="stat-value" id="cn-nodes">-</div></div>
                                <div class="stat-card"><div class="stat-label">Aristas</div><div class="stat-value" id="cn-edges">-</div></div>
                                <div class="stat-card"><div class="stat-label">SCC</div><div class="stat-value" id="cn-scc">-</div></div>
                            </div>
                            <!-- Imagen generada por backend (igual flujo que gráfico de ordenamiento) -->
                            <div class="chart-container hidden" id="citation-chart" style="margin-top: 10px;">
                                <img id="citation-graph-img" src="" alt="Grafo de citaciones (PNG)"/>
                            </div>
                            <div class="chart-container" style="background: rgba(255,255,255,0.02); overflow:hidden;">
                                <canvas id="citation-graph-canvas" style="width:100%; height:auto; display:block; background: rgba(15,23,42,0.6); border-radius: 12px;"></canvas>
                            </div>
                            <div class="form-group">
                                <label>🧭 Camino mínimo (Dijkstra)</label>
                                <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                                    <select id="cn-source" style="min-width:260px;"></select>
                                    <span style="color: var(--text-muted)">→</span>
                                    <select id="cn-target" style="min-width:260px;"></select>
                                    <button class="btn" onclick="computeCitationShortestPath()">Calcular</button>
                                </div>
                                <div id="cn-path-result" style="margin-top:8px; color: var(--text-muted);"></div>
                            </div>
                            <div class="form-group">
                                <label>🧩 Componentes fuertemente conexas</label>
                                <div id="cn-scc-list" class="log-box" style="height: 200px; overflow:auto;"></div>
                            </div>
                            <div class="form-group">
                                <label>🏁 Top 10 caminos mínimos (Dijkstra)</label>
                                <div id="cn-top-paths" class="log-box" style="height: 200px; overflow:auto;"></div>
                            </div>
                            <div class="form-group">
                                <label>🧩 SCC más grandes</label>
                                <div id="cn-top-sccs" class="log-box" style="height: 160px; overflow:auto;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- NUEVO: Grafo de Coocurrencia (No dirigido, Solo Algoritmos) -->
                    <div class="card" style="overflow: visible;">
                        <h3>📎 Grafo de Coocurrencia (No dirigido) <span class="tooltip info-icon" tabindex="0" aria-label="Conecta términos (palabras/keywords) que aparecen juntos en el mismo documento. Útil para ver clústeres de conceptos y términos más conectados." data-tip="Conecta términos (palabras/keywords) que aparecen juntos en el mismo documento. Útil para ver clústeres de conceptos y términos más conectados.">ⓘ</span></h3>
                        <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 14px;">Construye un grafo no dirigido de coocurrencia de términos a partir de abstracts y keywords.</p>
                        <div class="form-group">
                            <label>📁 Fuente de artículos</label>
                            <div style="display:flex; gap:10px; flex-wrap: wrap; align-items:center;">
                                <button class="btn btn-secondary" onclick="selectFile('analysis-csv')">Elegir CSV…</button>
                                <span style="color: var(--text-muted);">Usa el CSV seleccionado o el unificado/ordenado del pipeline.</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>⚙️ Opciones</label>
                            <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
                                <label class="checkbox-label"><span>Máx. docs:</span> <input type="number" id="cooc-limit" min="2" value="120" style="width:100px; margin-left:8px;"></label>
                                <label class="checkbox-label"><span>Min. longitud término:</span> <input type="number" id="cooc-minlen" min="2" value="3" style="width:100px; margin-left:8px;"></label>
                                <label class="checkbox-label"><span>Min. doc freq:</span> <input type="number" id="cooc-mindf" min="1" value="1" style="width:100px; margin-left:8px;"></label>
                                <label class="checkbox-label"><input type="checkbox" id="cooc-use-concepts"> <span>Enriquecer con conceptos (GAIE)</span></label>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="runCooccurrenceAnalysis()">Generar grafo</button>
                        <div class="progress-container" id="cooc-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" id="cooc-fill" style="width: 0%">0%</div>
                            </div>
                            <div class="status-message" id="cooc-status">Esperando...</div>
                            <div class="substatus" id="cooc-substatus"></div>
                        </div>
                        <div class="mt-20">
                            <h3>🖼️ Grafo de coocurrencia y métricas</h3>
                            <div class="results-grid">
                                <div class="stat-card"><div class="stat-label">Términos</div><div class="stat-value" id="cooc-nodes">-</div></div>
                                <div class="stat-card"><div class="stat-label">Aristas</div><div class="stat-value" id="cooc-edges">-</div></div>
                                <div class="stat-card"><div class="stat-label">Componentes</div><div class="stat-value" id="cooc-comps">-</div></div>
                            </div>
                            <div class="chart-container" style="background: rgba(255,255,255,0.02); overflow:hidden;">
                                <img id="cooc-img" src="" alt="Grafo de coocurrencia (PNG)"/>
                            </div>
                            <div class="file-buttons">
                                <button class="file-btn" onclick="openFile('cooc_graph')">📎 Abrir Grafo Coocurrencias (PNG)</button>
                            </div>
                            <div class="form-group">
                                <label>📈 Top grados (términos más conectados)</label>
                                <div id="cooc-degrees" class="log-box" style="height: 160px; overflow:auto;"></div>
                            </div>
                            <div class="form-group">
                                <label>🔗 Componentes conexas</label>
                                <div id="cooc-components" class="log-box" style="height: 160px; overflow:auto;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Estado global
        let currentSection = 'dashboard';
        let selectedFiles = {};
        let currentResults = {};
        
        // Consola global de logs
        window.appendLog = function(message) {
            try {
                const box = document.getElementById('global-log');
                if (!box) return;
                const line = document.createElement('div');
                line.textContent = message;
                box.appendChild(line);
                while (box.childNodes.length > 2000) {
                    box.removeChild(box.firstChild);
                }
                box.scrollTop = box.scrollHeight;
            } catch (e) {
                // noop
            }
        };
        
        // Navegación
        function showSection(section) {
            document.querySelectorAll('.section').forEach(el => {
                el.classList.remove('active');
            });
            
            document.querySelectorAll('.menu-item').forEach(el => {
                el.classList.remove('active');
            });
            
            document.getElementById(section).classList.add('active');
            event.target.closest('.menu-item').classList.add('active');
            
            const titles = {
                'dashboard': 'Dashboard Principal',
                'pipeline': 'Pipeline Completo',
                'scraping': 'Solo Scraping',
                'cleaning': 'Solo Limpieza',
                'analysis': 'Solo Análisis de Algoritmos'
            };
            document.getElementById('section-title').textContent = titles[section];
            
            currentSection = section;
        }
        
        // Toggle database selection
        function toggleDB(prefix, db) {
            const checkbox = document.getElementById(`${prefix}-db-${db}`);
            const card = checkbox.closest('.db-card');
            
            checkbox.checked = !checkbox.checked;
            
            if (checkbox.checked) {
                card.classList.add('selected');
            } else {
                card.classList.remove('selected');
            }
        }
        
        // Helper: gestionar barras de progreso por sección
        function setSectionProgress(prefix, active, percent = 0, statusText = '', subText = '') {
            const wrap = document.getElementById(prefix + '-progress');
            if (!wrap) return;
            if (active) wrap.classList.add('active'); else wrap.classList.remove('active');
            const fill = document.getElementById(prefix + '-fill');
            if (fill) {
                const p = Math.max(0, Math.min(100, percent|0));
                fill.style.width = p + '%';
                fill.textContent = p + '%';
            }
            const st = document.getElementById(prefix + '-status');
            if (st && statusText) st.textContent = statusText;
            const sub = document.getElementById(prefix + '-substatus');
            if (sub) sub.textContent = subText || '';
        }

        // Check availability
        function checkAvailability(prefix) {
            const query = document.getElementById(`${prefix}-query`).value;
            
            if (!query) {
                alert('Por favor ingresa un término de búsqueda');
                return;
            }
            
            const databases = [];
            ['ebsco', 'ieee'].forEach(db => {
                if (document.getElementById(`${prefix}-db-${db}`).checked) {
                    databases.push(db);
                }
            });
            
            if (databases.length < 2) {
                alert('Debes seleccionar al menos 2 bases de datos');
                return;
            }
            
            let email = '';
            let password = '';
            let showBrowser = true;
            if (prefix === 'pipeline') {
                const emailEl = document.getElementById('pipeline-email');
                const passEl = document.getElementById('pipeline-password');
                const showEl = document.getElementById('pipeline-show-browser');
                email = emailEl ? emailEl.value : '';
                password = passEl ? passEl.value : '';
                showBrowser = showEl ? showEl.checked : true;
            } else if (prefix === 'scraping') {
                const emailEl = document.getElementById('scraping-email');
                const passEl = document.getElementById('scraping-password');
                const showEl = document.getElementById('scraping-show-browser');
                email = emailEl ? emailEl.value : '';
                password = passEl ? passEl.value : '';
                showBrowser = showEl ? showEl.checked : true;
            }

            databases.forEach(db => {
                document.getElementById(`${prefix}-count-${db}`).textContent = 'Consultando...';
            });
            
            pywebview.api.get_availability(query, databases, email, password, showBrowser).then(results => {
                Object.keys(results).forEach(db => {
                    const count = results[db];
                    const countElement = document.getElementById(`${prefix}-count-${db}`);
                    
                    if (count === -1) {
                        countElement.textContent = '⚠️ Requiere login';
                        countElement.style.color = 'var(--warning)';
                    } else if (count === 0) {
                        countElement.textContent = '0 resultados';
                    } else {
                        countElement.textContent = `${count.toLocaleString()} resultados`;
                    }
                });
            }).catch(error => {
                alert('Error al verificar disponibilidad: ' + error);
                databases.forEach(db => {
                    document.getElementById(`${prefix}-count-${db}`).textContent = 'Error';
                });
            });
        }
        
        // Start full pipeline
        function startFullPipeline() {
            const email = document.getElementById('pipeline-email').value;
            const password = document.getElementById('pipeline-password').value;
            const query = document.getElementById('pipeline-query').value;
            const showBrowser = document.getElementById('pipeline-show-browser').checked;
            
            const databases = [];
            ['ebsco', 'ieee'].forEach(db => {
                if (document.getElementById(`pipeline-db-${db}`).checked) {
                    databases.push(db);
                }
            });
            
            if (!email || !password) {
                alert('Por favor ingresa email y contraseña');
                return;
            }
            
            if (!query) {
                alert('Por favor ingresa un término de búsqueda');
                return;
            }
            
            if (databases.length < 2) {
                alert('Debes seleccionar al menos 2 bases de datos');
                return;
            }
            
            const downloadAll = document.querySelector('input[name="pipeline-amount"]:checked').value === 'all';
            const customAmount = parseInt(document.getElementById('pipeline-custom-amount').value);
            
            document.getElementById('pipeline-progress').classList.add('active');
            // Mensaje calmante para el usuario mientras arranca el pipeline (incluye scraping)
            const pStatus = document.getElementById('pipeline-status');
            const pSub = document.getElementById('pipeline-substatus');
            if (pStatus) pStatus.textContent = 'Iniciando pipeline (scraping, limpieza y análisis)… Esto puede tardar unos minutos.';
            if (pSub) pSub.textContent = 'Por favor no cierres la ventana ni la aplicación durante el proceso.';

            pywebview.api.start_full_pipeline(
                query,
                databases,
                downloadAll,
                customAmount,
                query.replace(/ /g, '_'),
                email,
                password,
                showBrowser,
                // Opciones de similitud en pipeline
                document.getElementById('pipeline-sim-enable').checked,
                parseInt(document.getElementById('pipeline-sim-limit').value),
                document.getElementById('pipe-only-abs').checked,
                document.getElementById('pipe-use-classic').checked,
                document.getElementById('pipe-use-ai').checked,
                {
                    levenshtein: document.getElementById('pipe-lev').checked,
                    jaro: document.getElementById('pipe-jaro').checked,
                    tfidf: document.getElementById('pipe-tfidf').checked,
                    coseno: document.getElementById('pipe-cos').checked,
                },
                {
                    sbert: document.getElementById('pipe-sbert').checked,
                    hf: document.getElementById('pipe-hf').checked,
                }
            ).then(res => {
                console.log('Pipeline iniciado:', res);
            });
        }
        
        // Start scraping only
        function startScraping() {
            const email = document.getElementById('scraping-email').value;
            const password = document.getElementById('scraping-password').value;
            const query = document.getElementById('scraping-query').value;
            const showBrowser = document.getElementById('scraping-show-browser').checked;
            
            const databases = [];
            ['ebsco', 'ieee'].forEach(db => {
                if (document.getElementById(`scraping-db-${db}`).checked) {
                    databases.push(db);
                }
            });
            
            if (!email || !password) {
                alert('Por favor ingresa email y contraseña');
                return;
            }
            
            if (!query) {
                alert('Por favor ingresa un término de búsqueda');
                return;
            }
            
            if (databases.length < 2) {
                alert('Debes seleccionar al menos 2 bases de datos');
                return;
            }
            
            const downloadAll = document.querySelector('input[name="scraping-amount"]:checked').value === 'all';
            const customAmount = parseInt(document.getElementById('scraping-custom-amount').value);
            
            document.getElementById('scraping-progress').classList.add('active');
            // Mensaje calmante para el usuario mientras arranca el scraping
            const sStatus = document.getElementById('scraping-status');
            const sSub = document.getElementById('scraping-substatus');
            if (sStatus) sStatus.textContent = 'Procesando scraping… Esto puede tardar unos minutos según tu red y la cantidad de resultados.';
            if (sSub) sSub.textContent = 'Puedes seguir viendo el log en vivo mientras trabajamos.';

            pywebview.api.start_scraping(
                query,
                databases,
                downloadAll,
                customAmount,
                email,
                password,
                showBrowser
            ).then(res => {
                console.log('Scraping iniciado:', res);
            });
        }
        
        // Start cleaning
        function startCleaning() {
            const files = {
                ebsco: selectedFiles['cleaning-ebsco'],
                ieee: selectedFiles['cleaning-ieee']
            };
            
            const validFiles = Object.values(files).filter(f => f);
            
            if (validFiles.length < 2) {
                alert('Debes seleccionar al menos 2 archivos CSV');
                return;
            }
            
            document.getElementById('cleaning-progress').classList.add('active');
            
            pywebview.api.start_cleaning('cleaned_data', files).then(response => {
                console.log('Limpieza iniciada:', response);
            });
        }
        
        // Start analysis
        function startAnalysis() {
            const file = selectedFiles['analysis-csv'];
            
            if (!file) {
                alert('Por favor selecciona un archivo CSV');
                return;
            }
            
            document.getElementById('analysis-progress').classList.add('active');
            
            pywebview.api.start_analysis('analysis_results', file).then(response => {
                console.log('Análisis iniciado:', response);
            });
        }
        
        // Select file
        function selectFile(id) {
            pywebview.api.select_csv_file().then(filepath => {
                if (filepath) {
                    selectedFiles[id] = filepath;
                    const filename = filepath.split(/[\\/]/).pop();
                    document.getElementById(`${id}-file`).textContent = filename;
                }
            });
        }
        
        // Open file
        function openFile(type) {
            let filepath = '';
            
            if (type === 'unified') {
                filepath = currentResults.unified_file;
            } else if (type === 'sorted') {
                filepath = (currentResults.best_sorted && currentResults.best_sorted.sorted_file) ? currentResults.best_sorted.sorted_file : '';
            } else if (type === 'chart') {
                filepath = currentResults.chart_file;
            } else if (type === 'authors') {
                filepath = currentResults.authors_file;
            } else if (type === 'citation_graph') {
                const cn = currentResults.citation_network || {};
                filepath = cn.graph_file || '';
            } else if (type === 'cooc_graph') {
                const cn = currentResults.citation_network || {};
                const co = cn.cooccurrence || {};
                filepath = co.graph_file || (currentResults.cooccurrence ? (currentResults.cooccurrence.graph_file || '') : '');
            }
            
            if (filepath) {
                pywebview.api.open_file(filepath);
            }
        }
        
        // Update status from backend
        window.updateStatus = function(status) {
            const phase = status.phase;
            const progress = status.progress;
            const message = status.message;
            const substatus = status.substatus;
            
            let prefix = currentSection;
            if (phase === 'login' || phase === 'scraping' || phase === 'cleaning' || phase === 'analysis') {
                if (currentSection === 'pipeline') {
                    prefix = 'pipeline';
                } else {
                    prefix = phase;
                }
            }
            
            const fillElement = document.getElementById(`${prefix}-fill`);
            const statusElement = document.getElementById(`${prefix}-status`);
            const substatusElement = document.getElementById(`${prefix}-substatus`);
            
            if (fillElement) {
                fillElement.style.width = progress + '%';
                fillElement.textContent = progress + '%';
            }
            
            if (statusElement) {
                statusElement.textContent = message;
            }
            
            if (substatusElement) {
                substatusElement.textContent = substatus;
            }
            
            if (progress === 100) {
                if (phase === 'analysis' && status.results.algorithm_times) {
                    showAnalysisResults(prefix, status.results);
                    currentResults = status.results;
                } else if (phase === 'cleaning' && status.results.total_records) {
                    showCleaningResults(prefix, status.results);
                    currentResults = status.results;
                }
            }
        };
        
        // Show analysis results
        function showAnalysisResults(prefix, results) {
            const resultsDiv = document.getElementById(`${prefix}-results`);
            resultsDiv.classList.remove('hidden');
            
            if (results.chart_base64) {
                const chartImg = document.getElementById(`${prefix}-chart-img`);
                chartImg.src = 'data:image/png;base64,' + results.chart_base64;
            }
            
            const list = document.getElementById(`${prefix}-algorithm-list`);
            list.innerHTML = '';
            
            let rank = 1;
            for (const [name, time] of Object.entries(results.algorithm_times)) {
                const li = document.createElement('li');
                li.className = 'algorithm-item';
                li.innerHTML = `
                    <span class="algorithm-rank">#${rank}</span>
                    <span class="algorithm-name">${name}</span>
                    <span class="algorithm-time">${time.toFixed(3)} ms</span>
                `;
                list.appendChild(li);
                rank++;
            }

            // Renderizar similitud (si viene en resultados y estamos en pipeline)
            if (results.similarity && prefix === 'pipeline') {
                const sim = results.similarity;
                const contId = 'pipeline-sim-results';
                const cont = document.getElementById(contId);
                if (cont) {
                    cont.innerHTML = 'Generando resultados de similitud…';
                    renderSimilarityResults(sim.labels || [], sim.results || {}, contId);
                }
            }

            // Renderizar conceptos (si viene en resultados y estamos en pipeline)
            if (results.concepts && prefix === 'pipeline') {
                renderConceptsResults(results.concepts, 'pipeline-concepts-results');
            }

            // Renderizar clustering jerárquico (pipeline)
            if (results.clustering && prefix === 'pipeline') {
                renderClusteringResults(results.clustering, 'pipeline-hc-results');
            }

            // Renderizar red de citaciones (pipeline)
            if (results.citation_network && prefix === 'pipeline') {
                const statsRefs = {
                    nodes: document.getElementById('pl-cn-nodes'),
                    edges: document.getElementById('pl-cn-edges'),
                    scc: document.getElementById('pl-cn-scc'),
                };
                renderCitationResults(results.citation_network, 'pipeline-citation-canvas', 'pl-cn-source', 'pl-cn-target', 'pl-cn-path-result', 'pl-cn-scc-list', statsRefs);
            }

            // Renderizar red de citaciones (pipeline)
            if (results.citation_network && prefix === 'pipeline') {
                const statsRefs = {
                    nodes: document.getElementById('pl-cn-nodes'),
                    edges: document.getElementById('pl-cn-edges'),
                    scc: document.getElementById('pl-cn-scc')
                };
                renderCitationResults(results.citation_network, 'pipeline-citation-canvas', 'pl-cn-source', 'pl-cn-target', 'pl-cn-path-result', 'pl-cn-scc-list', statsRefs);
            }
        }
        
        // Show cleaning results
        function showCleaningResults(prefix, results) {
            const resultsDiv = document.getElementById(`${prefix}-results`);
            resultsDiv.classList.remove('hidden');
            
            document.getElementById(`${prefix}-total`).textContent = results.total_records.toLocaleString();
        }

        // ==================== NUEVO: Lógica de Similitud Textual ====================
        let algoCSVPath = null;
        let algoArticles = [];
        let algoSelected = new Set();

        function selectCSVForAlgorithms() {
            pywebview.api.select_csv_file().then(fp => {
                if (fp) {
                    loadArticlesForAlgorithms(fp);
                }
            });
        }

        function loadArticlesForAlgorithms(csvPath = null) {
            document.getElementById('algo-articles-list').innerHTML = 'Cargando…';
            pywebview.api.get_articles_for_algorithms(csvPath, 500).then(resp => {
                if (resp.success) {
                    algoCSVPath = resp.file;
                    document.getElementById('algo-csv-file').textContent = (resp.file || '').split(/[\\/]/).pop();
                    renderAlgoArticles(resp.articles || []);
                } else {
                    document.getElementById('algo-articles-list').innerHTML = `<div class="alert alert-warning">${resp.message || 'Error al cargar artículos'}</div>`;
                }
            });
        }

        function renderAlgoArticles(articles) {
            algoArticles = articles;
            algoSelected.clear();
            const cont = document.getElementById('algo-articles-list');
            if (!articles.length) {
                cont.innerHTML = '<span style="color: var(--text-muted)">Sin artículos para mostrar.</span>';
                return;
            }
            const frag = document.createDocumentFragment();
            articles.forEach(a => {
                const div = document.createElement('div');
                div.style.padding = '6px 8px';
                div.style.borderBottom = '1px solid var(--border)';
                div.innerHTML = `
                    <label class="checkbox-label" style="display:flex; gap:10px; align-items:flex-start;">
                        <input type="checkbox" data-idx="${a.index}" onchange="toggleArticleSelection(event)">
                        <span>
                            <strong>${(a.title || '').replace(/</g,'&lt;')}</strong>
                            <div style="color: var(--text-muted); font-size: 12px;">${(a.abstract_preview || '').replace(/</g,'&lt;')}</div>
                        </span>
                    </label>`;
                frag.appendChild(div);
            });
            cont.innerHTML = '';
            cont.appendChild(frag);
        }

        function toggleArticleSelection(ev) {
            const cb = ev.target;
            const idx = parseInt(cb.getAttribute('data-idx'));
            if (cb.checked) algoSelected.add(idx); else algoSelected.delete(idx);
        }

        function selectAllArticles(flag) {
            const cont = document.getElementById('algo-articles-list');
            cont.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                cb.checked = !!flag;
                const idx = parseInt(cb.getAttribute('data-idx'));
                if (flag) algoSelected.add(idx); else algoSelected.delete(idx);
            });
        }

        function runSimilarityAnalysis() {
            const indices = Array.from(algoSelected);
            if (indices.length < 2) {
                window.appendLog('⚠️ Selecciona al menos 2 artículos para analizar.');
                return;
            }
            setSectionProgress('algo-sim', true, 10, 'Calculando similitud…', 'Comparando textos seleccionados');
            const useClassic = document.getElementById('algoUseClassic').checked;
            const useAI = document.getElementById('algoUseAI').checked;
            // Opciones granulares
            const classicOptions = {
                levenshtein: document.getElementById('algoLev').checked,
                jaro: document.getElementById('algoJaro').checked,
                tfidf: document.getElementById('algoTFIDF').checked,
                coseno: document.getElementById('algoCos').checked,
            };
            const aiOptions = {
                sbert: document.getElementById('algoSBERT').checked,
                hf: document.getElementById('algoHF').checked,
            };
            const resDiv = document.getElementById('algo-results');
            resDiv.innerHTML = 'Calculando…';
            pywebview.api.analyze_similarity(indices, algoCSVPath, useClassic, useAI, classicOptions, aiOptions).then(resp => {
                if (!resp.success) {
                    resDiv.innerHTML = `<div class="alert alert-warning">${resp.message || 'Error en el análisis'}</div>`;
                    setSectionProgress('algo-sim', true, 100, 'Error en similitud', 'Revisa las opciones o el archivo fuente');
                    setTimeout(() => setSectionProgress('algo-sim', false, 0, 'Esperando...', ''), 900);
                    return;
                }
                renderSimilarityResults(resp.labels || [], resp.results || {}, 'algo-results');
                setSectionProgress('algo-sim', true, 100, 'Completado', 'Resultados generados');
                setTimeout(() => setSectionProgress('algo-sim', false, 0, 'Esperando...', ''), 800);
            });
        }

        function renderSimilarityResults(labels, results, containerId = 'algo-results') {
            const resDiv = document.getElementById(containerId);
            const order = ['Levenshtein','Jaro-Winkler','TF-IDF','Coseno','SBERT','HF-MeanPooling'];
            const frag = document.createDocumentFragment();

            // Mostrar errores de backend (p.ej., falta de librerías IA)
            if (results.ClasicosError) {
                const warn = document.createElement('div');
                warn.className = 'alert alert-warning';
                warn.innerHTML = `<span>⚠️</span><span>${(results.ClasicosError+'').replace(/</g,'&lt;')}</span>`;
                frag.appendChild(warn);
            }
            if (results.IAError) {
                const warn = document.createElement('div');
                warn.className = 'alert alert-warning';
                warn.innerHTML = `<span>⚠️</span><span>${(results.IAError+'').replace(/</g,'&lt;')}</span>`;
                frag.appendChild(warn);
            }
            order.forEach(key => {
                if (!results[key]) return;
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `<h3>${key}</h3>`;
                const pairs = results[key].pairs || [];
                if (!pairs.length) {
                    const p = document.createElement('p');
                    p.style.color = 'var(--text-muted)';
                    p.textContent = 'Sin pares destacados o no disponible.';
                    card.appendChild(p);
                } else {
                    const tbl = document.createElement('table');
                    tbl.style.width = '100%';
                    tbl.style.borderCollapse = 'collapse';
                    tbl.innerHTML = '<thead><tr><th style="text-align:left; padding:6px;">Par</th><th style="text-align:right; padding:6px;">Score</th></tr></thead>';
                    const tb = document.createElement('tbody');
                    pairs.forEach(p => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td style="padding:6px; border-top:1px solid var(--border);">${(labels[p.i]||'Doc '+p.i)} ⇄ ${(labels[p.j]||'Doc '+p.j)}</td>
                            <td style="padding:6px; border-top:1px solid var(--border); text-align:right;">${(p.score||0).toFixed(3)}</td>`;
                        tb.appendChild(tr);
                    });
                    tbl.appendChild(tb);
                    card.appendChild(tbl);
                }
                frag.appendChild(card);
            });
            resDiv.innerHTML = '';
            resDiv.appendChild(frag);
        }

        // ==================== NUEVO: Clustering Jerárquico ====================
        function runClusteringAnalysis() {
            const file = selectedFiles['analysis-csv'] || (currentResults && (currentResults.unified_file || currentResults.similarity_source)) || null;
            const algos = [];
            if (document.getElementById('hc-single').checked) algos.push('single');
            if (document.getElementById('hc-complete').checked) algos.push('complete');
            if (document.getElementById('hc-average').checked) algos.push('average');
            const maxdocs = parseInt(document.getElementById('hc-maxdocs').value) || 120;
            const cont = document.getElementById('hc-results');
            if (cont) cont.innerHTML = 'Generando…';
            setSectionProgress('hc', true, 12, 'Generando dendrogramas…', 'Calculando distancias y estructura jerárquica');
            pywebview.api.analyze_hierarchical_clustering(file, maxdocs, algos).then(resp => {
                if (!resp || !resp.success) {
                    cont.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${((resp && resp.message) || 'Error en clustering').replace(/</g,'&lt;')}</span></div>`;
                    setSectionProgress('hc', true, 100, 'Error en clustering', 'Revisa los parámetros o el archivo');
                    setTimeout(() => setSectionProgress('hc', false, 0, 'Esperando...', ''), 900);
                    return;
                }
                renderClusteringResults(resp.results, 'hc-results');
                setSectionProgress('hc', true, 100, 'Completado', 'Dendrogramas generados');
                setTimeout(() => setSectionProgress('hc', false, 0, 'Esperando...', ''), 800);
            }).catch(err => {
                cont.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${String(err).replace(/</g,'&lt;')}</span></div>`;
                setSectionProgress('hc', true, 100, 'Error en clustering', 'Consulta la consola para más detalles');
                setTimeout(() => setSectionProgress('hc', false, 0, 'Esperando...', ''), 1000);
            });
        }

        function renderClusteringResults(data, containerId) {
            const cont = document.getElementById(containerId);
            if (!cont) return;
            const frag = document.createDocumentFragment();

            // Resumen CCC
            const summary = document.createElement('div');
            summary.className = 'card';
            const best = data.best || {};
            let html = '<h3>📊 Coherencia (Cophenetic Correlation)</h3>';
            html += '<table style="width:100%; border-collapse:collapse"><thead><tr><th style="text-align:left; padding:6px;">Algoritmo</th><th style="text-align:right; padding:6px;">CCC</th></tr></thead><tbody>';
            (data.algorithms||[]).forEach(a => {
                const row = data.results && data.results[a];
                if (!row || row.error) return;
                const v = (row.ccc!=null && row.ccc.toFixed) ? row.ccc.toFixed(4) : row.ccc;
                html += `<tr><td style="padding:6px; border-top:1px solid var(--border);">${a}</td><td style="padding:6px; border-top:1px solid var(--border); text-align:right;">${v}</td></tr>`;
            });
            html += '</tbody></table>';
            if (best && best.algorithm) {
                html += `<div style="margin-top:8px; color: var(--text-muted);">Mejor: <strong>${best.algorithm}</strong> (CCC=${(best.ccc && best.ccc.toFixed) ? best.ccc.toFixed(4) : best.ccc})</div>`;
            }
            summary.innerHTML = html;
            frag.appendChild(summary);

            // Dendrogramas
            (data.algorithms||[]).forEach(a => {
                const row = data.results && data.results[a];
                if (!row || row.error || !row.dendrogram_base64) return;
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `<h3>${a}</h3><img style="width:100%; height:auto; border-radius:8px;" src="data:image/png;base64,${row.dendrogram_base64}" alt="Dendrograma ${a}">`;
                frag.appendChild(card);
            });

            cont.innerHTML = '';
            cont.appendChild(frag);
        }

        // ==================== NUEVO: Lógica de Conceptos GAIE ====================
        function runConceptsAnalysis() {
            const file = selectedFiles['analysis-csv'] || (currentResults && currentResults.unified_file) || null;
            const cont = document.getElementById('concepts-results');
            if (cont) cont.innerHTML = 'Analizando…';
            setSectionProgress('concepts', true, 8, 'Analizando conceptos…', 'Extrayendo términos y TF‑IDF');
            pywebview.api.analyze_concepts(file, 15).then(resp => {
                const c = document.getElementById('concepts-results');
                if (!resp || !resp.success) {
                    if (c) c.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${((resp && resp.message) || 'Error en análisis de conceptos').replace(/</g,'&lt;')}</span></div>`;
                    setSectionProgress('concepts', true, 100, 'Error en conceptos', 'Revisa el archivo o el tamaño del conjunto');
                    setTimeout(() => setSectionProgress('concepts', false, 0, 'Esperando...', ''), 900);
                    return;
                }
                renderConceptsResults(resp.results, 'concepts-results');
                setSectionProgress('concepts', true, 100, 'Completado', 'Términos y métricas generadas');
                setTimeout(() => setSectionProgress('concepts', false, 0, 'Esperando...', ''), 800);
            }).catch(err => {
                const c = document.getElementById('concepts-results');
                if (c) c.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${String(err).replace(/</g,'&lt;')}</span></div>`;
                setSectionProgress('concepts', true, 100, 'Error en conceptos', 'Consulta la consola para más detalles');
                setTimeout(() => setSectionProgress('concepts', false, 0, 'Esperando...', ''), 1000);
            });
        }

        function renderConceptsResults(data, containerId) {
            const cont = document.getElementById(containerId);
            if (!cont) return;
            const frag = document.createDocumentFragment();

            // Semillas
            const seedCard = document.createElement('div');
            seedCard.className = 'card';
            seedCard.innerHTML = `<h3>📌 Términos Semilla</h3>`;
            const st = document.createElement('table');
            st.style.width = '100%'; st.style.borderCollapse = 'collapse';
            st.innerHTML = '<thead><tr><th style="text-align:left; padding:6px;">Término</th><th style="text-align:right; padding:6px;">Docs</th><th style="text-align:right; padding:6px;">Ocurrencias</th></tr></thead>';
            const stb = document.createElement('tbody');
            (data.seed_stats||[]).forEach(r => {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td style=\"padding:6px; border-top:1px solid var(--border);\">${(r.term||'').replace(/</g,'&lt;')}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${(r.docs_with_term||0)}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${(r.total_occurrences||0)}</td>`;
                stb.appendChild(tr);
            });
            st.appendChild(stb); seedCard.appendChild(st); frag.appendChild(seedCard);

            // Generados
            const genCard = document.createElement('div');
            genCard.className = 'card';
            genCard.innerHTML = `<h3>✨ Términos Generados (top ${(data.generated_terms||[]).length})</h3>`;
            const gt = document.createElement('table');
            gt.style.width = '100%'; gt.style.borderCollapse = 'collapse';
            gt.innerHTML = '<thead><tr><th style="text-align:left; padding:6px;">Término</th><th style="text-align:right; padding:6px;">Docs</th><th style="text-align:right; padding:6px;">Ocurrencias</th><th style="text-align:right; padding:6px;">TF-IDF</th><th style="text-align:right; padding:6px;">Precisión P(cat|t)</th></tr></thead>';
            const gtb = document.createElement('tbody');
            (data.generated_terms||[]).forEach(r => {
                const tr = document.createElement('tr');
                const tfidf = (r.tfidf_score!=null && typeof r.tfidf_score.toFixed==='function') ? r.tfidf_score.toFixed(4) : r.tfidf_score;
                const prec = (r.precision_cat_given_term!=null && typeof r.precision_cat_given_term.toFixed==='function') ? r.precision_cat_given_term.toFixed(3) : r.precision_cat_given_term;
                tr.innerHTML = `<td style=\"padding:6px; border-top:1px solid var(--border);\">${(r.term||'').replace(/</g,'&lt;')}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${(r.docs_with_term||0)}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${(r.total_occurrences||0)}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${tfidf ?? ''}</td>
                                <td style=\"padding:6px; border-top:1px solid var(--border); text-align:right;\">${prec ?? ''}</td>`;
                gtb.appendChild(tr);
            });
            gt.appendChild(gtb); genCard.appendChild(gt);
            const avg = document.createElement('div');
            avg.style.marginTop = '8px';
            avg.style.color = 'var(--text-muted)';
            const avgVal = (data.avg_precision_generated||0);
            const avgStr = (avgVal && typeof avgVal.toFixed==='function') ? avgVal.toFixed(3) : avgVal;
            avg.textContent = `Precisión promedio (términos generados): ${ avgStr }`;
            genCard.appendChild(avg);
            frag.appendChild(genCard);

            cont.innerHTML = '';
            cont.appendChild(frag);
        }

        // ==================== NUEVO: Red de Citaciones ====================
        const citationState = {
            nodes: [],
            edges: [],
            positions: {},
            sccMap: {}, // nodeId -> compIndex
            colors: ['#60a5fa','#34d399','#f472b6','#fbbf24','#a78bfa','#fb7185','#4ade80','#22d3ee','#f59e0b','#c084fc'],
            lastHighlight: null,
            // pan & zoom
            tx: 0, ty: 0, scale: 1,
            // dragging
            dragging: null, dragDX: 0, dragDY: 0,
            // layout config
            layout: { iterations: 180, repulsion: 6000, stiffness: 0.02, damping: 0.85, idealLen: 120 },
            canvasListeners: {}
        };

        function runCitationNetworkAnalysis() {
            const file = selectedFiles['analysis-csv'] || (currentResults && (currentResults.unified_file || (currentResults.best_sorted && currentResults.best_sorted.sorted_file))) || null;
            const backend = (document.querySelector('input[name="cn-backend"]:checked') || {value:'classic'}).value;
            const threshold = parseFloat(document.getElementById('cn-threshold').value) || 0.6;
            const topk = parseInt(document.getElementById('cn-topk').value) || 3;
            const limit = parseInt(document.getElementById('cn-limit').value) || 120;
            const useConcepts = document.getElementById('cn-use-concepts').checked;
            const classicOptions = {
                levenshtein: document.getElementById('cn-cl-lev')?.checked ?? true,
                jarowinkler: document.getElementById('cn-cl-jw')?.checked ?? true,
                tfidf: document.getElementById('cn-cl-tfidf')?.checked ?? true,
                coseno: document.getElementById('cn-cl-cos')?.checked ?? true,
            };
            const aiOptions = {
                sbert: document.getElementById('cn-ai-sbert')?.checked ?? true,
                hf: document.getElementById('cn-ai-hf')?.checked ?? true,
            };
            const contStats = { nodes: document.getElementById('cn-nodes'), edges: document.getElementById('cn-edges'), scc: document.getElementById('cn-scc') };
            if (contStats.nodes) contStats.nodes.textContent = '…';
            if (contStats.edges) contStats.edges.textContent = '…';
            if (contStats.scc) contStats.scc.textContent = '…';
            const sccDiv = document.getElementById('cn-scc-list');
            if (sccDiv) sccDiv.innerHTML = 'Construyendo…';
            setSectionProgress('citation', true, 12, 'Construyendo red de citaciones…', 'Generando nodos, aristas y métricas');
            pywebview.api.analyze_citation_network(file, backend, threshold, topk, useConcepts, 'abstract', limit, classicOptions, aiOptions).then(resp => {
                if (!resp || !resp.success) {
                    if (sccDiv) sccDiv.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${((resp && resp.message) || 'Error construyendo la red').replace(/</g,'&lt;')}</span></div>`;
                    setSectionProgress('citation', true, 100, 'Error en la red', 'Revisa parámetros o el archivo');
                    setTimeout(() => setSectionProgress('citation', false, 0, 'Esperando...', ''), 900);
                    return;
                }
                renderCitationResults(resp.results, 'citation-graph-canvas', 'cn-source', 'cn-target', 'cn-path-result', 'cn-scc-list', contStats);
                setSectionProgress('citation', true, 100, 'Completado', 'Grafo generado');
                setTimeout(() => setSectionProgress('citation', false, 0, 'Esperando...', ''), 800);
            }).catch(err => {
                if (sccDiv) sccDiv.innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${String(err).replace(/</g,'&lt;')}</span></div>`;
                setSectionProgress('citation', true, 100, 'Error en la red', 'Consulta la consola para más detalles');
                setTimeout(() => setSectionProgress('citation', false, 0, 'Esperando...', ''), 1000);
            });
        }

        // Toggle de opciones según backend seleccionado
        (function() {
            function updateCNBackendOptions() {
                const backend = (document.querySelector('input[name="cn-backend"]:checked') || {value:'classic'}).value;
                const cl = document.getElementById('cn-classic-options');
                const ai = document.getElementById('cn-ai-options');
                if (backend === 'ia') {
                    if (cl) cl.style.display = 'none';
                    if (ai) ai.style.display = 'flex';
                } else {
                    if (cl) cl.style.display = 'flex';
                    if (ai) ai.style.display = 'none';
                }
            }
            const radios = document.querySelectorAll('input[name="cn-backend"]');
            radios.forEach(r => r.addEventListener('change', updateCNBackendOptions));
            // Inicializar estado
            setTimeout(updateCNBackendOptions, 0);
        })();

        function renderCitationResults(data, canvasId, srcSelId, dstSelId, pathOutId, sccListId, statsRefs) {
            // Asegurar canvas responsivo
            resizeGraphCanvas(canvasId);
            ensureCanvasResizeHandler(canvasId);
            // Imagen (como gráfico de ordenamiento)
            const img = document.getElementById('citation-graph-img');
            const imgWrap = document.getElementById('citation-chart');
            if (img) {
                if (data.graph_base64) {
                    img.src = 'data:image/png;base64,' + data.graph_base64;
                    if (imgWrap) imgWrap.classList.remove('hidden');
                } else {
                    img.src = '';
                    if (imgWrap) imgWrap.classList.add('hidden');
                }
            }
            // Imagen del grafo de coocurrencia (si existe)
            const coImg = document.getElementById('pipeline-cooc-img');
            if (coImg && data.cooccurrence && data.cooccurrence.graph_base64) {
                coImg.src = 'data:image/png;base64,' + data.cooccurrence.graph_base64;
            }
            // Stats
            if (statsRefs && statsRefs.nodes) statsRefs.nodes.textContent = (data.node_count||0);
            if (statsRefs && statsRefs.edges) statsRefs.edges.textContent = (data.edge_count||0);
            if (statsRefs && statsRefs.scc) statsRefs.scc.textContent = (data.scc_count||0);
            // Stats coocurrencia
            const coNodesRef = document.getElementById('pl-co-nodes');
            const coEdgesRef = document.getElementById('pl-co-edges');
            const coCompsRef = document.getElementById('pl-co-comps');
            if (data.cooccurrence) {
                if (coNodesRef) coNodesRef.textContent = data.cooccurrence.node_count || 0;
                if (coEdgesRef) coEdgesRef.textContent = data.cooccurrence.edge_count || 0;
                if (coCompsRef) coCompsRef.textContent = data.cooccurrence.component_count || 0;
            }
            // Guardar estado
            citationState.nodes = data.nodes || [];
            citationState.edges = data.edges || [];
            // Mapa SCC para colorear
            const sccMap = {};
            (data.sccs||[]).forEach((comp, idx) => comp.forEach(id => { sccMap[String(id)] = idx; }));
            citationState.sccMap = sccMap;
            // Posiciones iniciales aleatorias (mejora: layout por fuerzas)
            const W = (document.getElementById(canvasId)?.width || 980);
            const H = (document.getElementById(canvasId)?.height || 520);
            const pos = {};
            const N = citationState.nodes.length || 1;
            for (let i=0; i<N; i++) {
                const n = citationState.nodes[i];
                pos[n.id] = { x: (W*0.5) + 220*Math.cos(2*Math.PI*i/N), y: (H*0.5) + 220*Math.sin(2*Math.PI*i/N), vx:0, vy:0 };
            }
            citationState.positions = pos;
            // Ejecutar layout de fuerzas (rápido)
            runForceLayout(canvasId, 140);
            drawCitationGraph(canvasId);
            attachCanvasInteractions(canvasId);

            // Llenar selects
            const srcSel = document.getElementById(srcSelId);
            const dstSel = document.getElementById(dstSelId);
            if (srcSel && dstSel) {
                srcSel.innerHTML = '';
                dstSel.innerHTML = '';
                citationState.nodes.forEach(n => {
                    const o1 = document.createElement('option'); o1.value = n.id; o1.textContent = (n.label||n.id); srcSel.appendChild(o1);
                    const o2 = document.createElement('option'); o2.value = n.id; o2.textContent = (n.label||n.id); dstSel.appendChild(o2);
                });
            }

            // SCCs
            const sccDiv = document.getElementById(sccListId);
            if (sccDiv) {
                if (!data.sccs || !data.sccs.length) {
                    sccDiv.innerHTML = '<span style="color: var(--text-muted)">Sin SCC</span>';
                } else {
                    const frag = document.createDocumentFragment();
                    data.sccs.forEach((comp, idx) => {
                        const d = document.createElement('div');
                        d.style.padding = '6px 8px';
                        d.style.borderBottom = '1px solid var(--border)';
                        const names = comp.map(id => {
                            const n = citationState.nodes.find(x => x.id===String(id));
                            return (n && n.label) ? n.label : String(id);
                        });
                        d.innerHTML = `<strong>Componente #${idx+1}</strong> · ${names.join(', ').replace(/</g,'&lt;')}`;
                        frag.appendChild(d);
                    });
                    sccDiv.innerHTML = '';
                    sccDiv.appendChild(frag);
                }
            }

            // Top 10 caminos mínimos (Dijkstra) si existen
            const topPathsBlocks = [document.getElementById('cn-top-paths'), document.getElementById('pl-cn-top-paths')];
            topPathsBlocks.forEach(tpDiv => {
                if (!tpDiv) return;
                const tp = data.top_paths || [];
                if (!tp.length) {
                    tpDiv.innerHTML = '<span style="color: var(--text-muted)">Sin resultados</span>';
                    return;
                }
                const frag = document.createDocumentFragment();
                tp.forEach((e, i) => {
                    const d = document.createElement('div');
                    d.style.padding = '6px 8px';
                    d.style.borderBottom = '1px solid var(--border)';
                    const pathText = (e.path||[]).join(' → ').replace(/</g,'&lt;');
                    d.innerHTML = `<strong>#${i+1}</strong> · costo=${Number(e.cost).toFixed(3)} · ${pathText}`;
                    frag.appendChild(d);
                });
                tpDiv.innerHTML = '';
                tpDiv.appendChild(frag);
            });

            // Top SCCs por tamaño si existen
            const topSccBlocks = [document.getElementById('cn-top-sccs'), document.getElementById('pl-cn-top-sccs')];
            topSccBlocks.forEach(tsDiv => {
                if (!tsDiv) return;
                const ts = data.top_sccs || [];
                if (!ts.length) {
                    tsDiv.innerHTML = '<span style="color: var(--text-muted)">Sin resultados</span>';
                    return;
                }
                const frag = document.createDocumentFragment();
                ts.forEach((e, i) => {
                    const d = document.createElement('div');
                    d.style.padding = '6px 8px';
                    d.style.borderBottom = '1px solid var(--border)';
                    const names = (e.nodes||[]).join(', ').replace(/</g,'&lt;');
                    d.innerHTML = `<strong>#${i+1}</strong> · tamaño=${Number(e.size||0)} · ${names}`;
                    frag.appendChild(d);
                });
                tsDiv.innerHTML = '';
                tsDiv.appendChild(frag);
            });
            // Limpiar resultado de camino
            const pathOut = document.getElementById(pathOutId);
            if (pathOut) pathOut.innerHTML = '';

            // Listado de grados y componentes coocurrencia
            if (data.cooccurrence) {
                const degreesDiv = document.getElementById('pl-co-degrees');
                const compsDiv = document.getElementById('pl-co-components');
                if (degreesDiv) {
                    // Calcular grados -> a partir de aristas (no dirigido)
                    const degMap = {};
                    (data.cooccurrence.edges||[]).forEach(e => {
                        degMap[e.source] = (degMap[e.source]||0)+1;
                        degMap[e.target] = (degMap[e.target]||0)+1;
                    });
                    const degList = Object.entries(degMap).sort((a,b)=>b[1]-a[1]).slice(0,30);
                    if (!degList.length) {
                        degreesDiv.innerHTML = '<span style="color: var(--text-muted)">Sin datos</span>';
                    } else {
                        const frag = document.createDocumentFragment();
                        degList.forEach(([term,deg]) => {
                            const d = document.createElement('div');
                            d.style.padding='6px 8px'; d.style.borderBottom='1px solid var(--border)';
                            d.innerHTML = `<strong>${String(term).replace(/</g,'&lt;')}</strong> · grado=${deg}`;
                            frag.appendChild(d);
                        });
                        degreesDiv.innerHTML=''; degreesDiv.appendChild(frag);
                    }
                }
                if (compsDiv) {
                    const comps = data.cooccurrence.components || [];
                    if (!comps.length) {
                        compsDiv.innerHTML = '<span style="color: var(--text-muted)">Sin componentes</span>';
                    } else {
                        const frag = document.createDocumentFragment();
                        comps.forEach((c,idx)=>{
                            const d=document.createElement('div');
                            d.style.padding='6px 8px'; d.style.borderBottom='1px solid var(--border)';
                            d.innerHTML = `<strong>#${idx+1}</strong> · tamaño=${c.length} · ${c.join(', ').replace(/</g,'&lt;')}`;
                            frag.appendChild(d);
                        });
                        compsDiv.innerHTML=''; compsDiv.appendChild(frag);
                    }
                }
            }
        }

        function drawCitationGraph(canvasId, highlightPath=null) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            // Ajustar dimensiones reales del canvas según CSS/parent
            resizeGraphCanvas(canvasId);
            const ctx = canvas.getContext('2d');
            const W = canvas.width, H = canvas.height;
            ctx.clearRect(0,0,W,H);
            ctx.save();
            ctx.translate(W/2 + citationState.tx, H/2 + citationState.ty);
            ctx.scale(citationState.scale, citationState.scale);
            ctx.translate(-W/2, -H/2);
            // Edges
            ctx.lineWidth = 1.2;
            citationState.edges.forEach(e => {
                const a = citationState.positions[e.source];
                const b = citationState.positions[e.target];
                if (!a || !b) return;
                const isHL = (highlightPath && highlightPath.some(p => p.source===e.source && p.target===e.target));
                const base = isHL ? '#ef4444' : 'rgba(148,163,184,0.8)';
                ctx.strokeStyle = base;
                ctx.fillStyle = ctx.strokeStyle;
                // line
                ctx.beginPath();
                ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
                // arrowhead
                const ang = Math.atan2(b.y - a.y, b.x - a.x);
                const ah = 8 + 4*((+e.weight||0));
                ctx.beginPath();
                ctx.moveTo(b.x, b.y);
                ctx.lineTo(b.x - ah*Math.cos(ang - Math.PI/6), b.y - ah*Math.sin(ang - Math.PI/6));
                ctx.lineTo(b.x - ah*Math.cos(ang + Math.PI/6), b.y - ah*Math.sin(ang + Math.PI/6));
                ctx.closePath(); ctx.fill();
                // weight label
                const mx = (a.x + b.x)/2, my = (a.y + b.y)/2;
                ctx.fillStyle = '#cbd5e1';
                ctx.font = '12px Inter, sans-serif';
                if (e.weight!=null) ctx.fillText((+e.weight).toFixed(2), mx+4, my-4);
            });
            // Nodes
            citationState.nodes.forEach((n, i) => {
                const p = citationState.positions[n.id];
                if (!p) return;
                const r = 9;
                ctx.beginPath();
                ctx.arc(p.x, p.y, r, 0, Math.PI*2);
                const comp = citationState.sccMap[n.id] ?? i;
                const color = citationState.colors[comp % citationState.colors.length] || '#6366f1';
                ctx.fillStyle = color;
                ctx.fill();
                ctx.strokeStyle = 'rgba(255,255,255,0.8)';
                ctx.stroke();
                // label
                ctx.fillStyle = '#e2e8f0';
                ctx.font = '12px Inter, sans-serif';
                const label = (n.label || n.id);
                const txt = (label.length>42 ? (label.slice(0,39)+'…') : label);
                ctx.fillText(txt, p.x+10, p.y+4);
            });
            ctx.restore();
        }

        // -------------------- Responsividad del canvas --------------------
        function resizeGraphCanvas(canvasId) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            const parent = canvas.parentElement || canvas;
            const dpr = window.devicePixelRatio || 1;
            // ancho CSS disponible
            const cssW = Math.max(320, parent.clientWidth || 980);
            const cssH = Math.max(260, Math.round(cssW * 0.52)); // relación ~ 1.92:1
            // aplicar tamaño CSS
            canvas.style.width = cssW + 'px';
            canvas.style.height = cssH + 'px';
            // aplicar tamaño real para dibujo (HiDPI)
            const realW = Math.floor(cssW * dpr);
            const realH = Math.floor(cssH * dpr);
            if (canvas.width !== realW || canvas.height !== realH) {
                canvas.width = realW;
                canvas.height = realH;
            }
        }
        function ensureCanvasResizeHandler(canvasId) {
            if (!citationState.canvasListeners['resize_'+canvasId]) {
                const handler = () => { resizeGraphCanvas(canvasId); drawCitationGraph(canvasId); };
                window.addEventListener('resize', handler);
                citationState.canvasListeners['resize_'+canvasId] = handler;
            }
        }

        // -------------------- Layout por fuerzas (simple) --------------------
        function runForceLayout(canvasId, iters= citationState.layout.iterations) {
            const W = (document.getElementById(canvasId)?.width || 980);
            const H = (document.getElementById(canvasId)?.height || 520);
            const nodes = citationState.nodes;
            const edges = citationState.edges;
            const pos = citationState.positions;
            const cfg = citationState.layout;
            const areaK = Math.sqrt((W*H)/Math.max(1, nodes.length));
            const idealLen = cfg.idealLen || (2*areaK);
            for (let it=0; it<iters; it++) {
                // repulsión O(N^2)
                for (let i=0; i<nodes.length; i++) {
                    const a = nodes[i]; const pa = pos[a.id];
                    pa.fx = 0; pa.fy = 0;
                }
                for (let i=0; i<nodes.length; i++) {
                    const a = nodes[i]; const pa = pos[a.id];
                    for (let j=i+1; j<nodes.length; j++) {
                        const b = nodes[j]; const pb = pos[b.id];
                        const dx = pa.x - pb.x; const dy = pa.y - pb.y;
                        const d2 = dx*dx + dy*dy + 0.01; // evitar div/0
                        const d = Math.sqrt(d2);
                        const force = cfg.repulsion / d2;
                        const fx = force * dx / d; const fy = force * dy / d;
                        pa.fx += fx; pa.fy += fy;
                        pb.fx -= fx; pb.fy -= fy;
                    }
                }
                // atracción por aristas
                edges.forEach(e => {
                    const pa = pos[e.source]; const pb = pos[e.target]; if (!pa || !pb) return;
                    const dx = pb.x - pa.x; const dy = pb.y - pa.y; const d = Math.sqrt(dx*dx + dy*dy) + 0.01;
                    const w = (+e.weight || 0.5);
                    const spring = cfg.stiffness * (d - idealLen) * w;
                    const fx = spring * dx / d; const fy = spring * dy / d;
                    pa.fx += fx; pa.fy += fy; pb.fx -= fx; pb.fy -= fy;
                });
                // integrar
                for (let i=0; i<nodes.length; i++) {
                    const a = nodes[i]; const p = pos[a.id];
                    p.vx = (p.vx + p.fx) * cfg.damping;
                    p.vy = (p.vy + p.fy) * cfg.damping;
                    p.x += p.vx * 0.02; p.y += p.vy * 0.02;
                }
            }
        }

        // -------------------- Interacción: zoom/pan y arrastre --------------------
        function attachCanvasInteractions(canvasId) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || citationState.canvasListeners[canvasId]) return;
            function toWorld(x, y) {
                const W = canvas.width, H = canvas.height;
                const sx = (x - (W/2 + citationState.tx)) / citationState.scale + W/2;
                const sy = (y - (H/2 + citationState.ty)) / citationState.scale + H/2;
                return {x: sx, y: sy};
            }
            function hitNode(mx, my) {
                const p = toWorld(mx, my);
                for (let i=citationState.nodes.length-1; i>=0; i--) {
                    const n = citationState.nodes[i]; const q = citationState.positions[n.id];
                    if (!q) continue; const dx = p.x - q.x; const dy = p.y - q.y; if (dx*dx + dy*dy <= 11*11) return n.id;
                }
                return null;
            }
            const onWheel = (ev) => {
                ev.preventDefault();
                const delta = Math.sign(ev.deltaY);
                const factor = (delta>0)? 0.9 : 1.1;
                citationState.scale = Math.min(3, Math.max(0.2, citationState.scale * factor));
                drawCitationGraph(canvasId);
            };
            let isPanning = false, panStart = {x:0, y:0};
            const onDown = (ev) => {
                const rect = canvas.getBoundingClientRect();
                const x = ev.clientX - rect.left; const y = ev.clientY - rect.top;
                const nid = hitNode(x, y);
                if (nid) {
                    citationState.dragging = nid; const p = citationState.positions[nid];
                    const world = toWorld(x, y); citationState.dragDX = world.x - p.x; citationState.dragDY = world.y - p.y;
                } else {
                    isPanning = true; panStart = {x: ev.clientX, y: ev.clientY};
                }
            };
            const onMove = (ev) => {
                if (citationState.dragging) {
                    const rect = canvas.getBoundingClientRect();
                    const x = ev.clientX - rect.left; const y = ev.clientY - rect.top;
                    const world = toWorld(x, y);
                    const p = citationState.positions[citationState.dragging];
                    p.x = world.x - citationState.dragDX; p.y = world.y - citationState.dragDY;
                    drawCitationGraph(canvasId);
                } else if (isPanning) {
                    citationState.tx += (ev.clientX - panStart.x); citationState.ty += (ev.clientY - panStart.y);
                    panStart = {x: ev.clientX, y: ev.clientY};
                    drawCitationGraph(canvasId);
                }
            };
            const onUp = () => { citationState.dragging = null; isPanning = false; };
            canvas.addEventListener('wheel', onWheel, {passive: false});
            canvas.addEventListener('mousedown', onDown);
            window.addEventListener('mousemove', onMove);
            window.addEventListener('mouseup', onUp);
            citationState.canvasListeners[canvasId] = { onWheel, onDown, onMove, onUp };
        }

        function computeCitationShortestPath() {
            const s = document.getElementById('cn-source').value;
            const t = document.getElementById('cn-target').value;
            const out = document.getElementById('cn-path-result');
            if (out) out.innerHTML = 'Calculando…';
            pywebview.api.citation_shortest_path(s, t).then(resp => {
                if (!resp || !resp.success) {
                    if (out) out.innerHTML = `<span style="color: var(--text-muted)">${((resp && resp.message) || 'Sin camino o error').replace(/</g,'&lt;')}</span>`;
                    return;
                }
                const path = resp.path || [];
                const names = path.map(id => {
                    const n = citationState.nodes.find(x => x.id===String(id));
                    return (n && n.label) ? n.label : String(id);
                });
                if (out) out.innerHTML = `Distancia: <strong>${resp.distance==null? '∞' : resp.distance.toFixed? resp.distance.toFixed(3): resp.distance}</strong><br>Camino: ${names.join(' → ').replace(/</g,'&lt;')}`;
                // Highlight path on graph
                const pairs = [];
                for (let i=0; i+1<path.length; i++) pairs.push({source: String(path[i]), target: String(path[i+1])});
                drawCitationGraph('citation-graph-canvas', pairs);
            }).catch(err => {
                if (out) out.innerHTML = `<span style="color: var(--text-muted)">${String(err).replace(/</g,'&lt;')}</span>`;
            });
        }

        function computePipelineCitationShortestPath() {
            const s = document.getElementById('pl-cn-source').value;
            const t = document.getElementById('pl-cn-target').value;
            const out = document.getElementById('pl-cn-path-result');
            if (out) out.innerHTML = 'Calculando…';
            pywebview.api.citation_shortest_path(s, t).then(resp => {
                if (!resp || !resp.success) {
                    if (out) out.innerHTML = `<span style=\"color: var(--text-muted)\">${((resp && resp.message) || 'Sin camino o error').replace(/</g,'&lt;')}</span>`;
                    return;
                }
                const path = resp.path || [];
                const names = path.map(id => {
                    const n = citationState.nodes.find(x => x.id===String(id));
                    return (n && n.label) ? n.label : String(id);
                });
                if (out) out.innerHTML = `Distancia: <strong>${resp.distance==null? '∞' : resp.distance.toFixed? resp.distance.toFixed(3): resp.distance}</strong><br>Camino: ${names.join(' → ').replace(/</g,'&lt;')}`;
                const pairs = [];
                for (let i=0; i+1<path.length; i++) pairs.push({source: String(path[i]), target: String(path[i+1])});
                drawCitationGraph('pipeline-citation-canvas', pairs);
            }).catch(err => {
                if (out) out.innerHTML = `<span style=\"color: var(--text-muted)\">${String(err).replace(/</g,'&lt;')}</span>`;
            });
        }

        // ==================== NUEVO: Grafo de Coocurrencia (Solo Algoritmos) ====================
        function runCooccurrenceAnalysis() {
            const file = selectedFiles['analysis-csv'] || (currentResults && (currentResults.unified_file || (currentResults.best_sorted && currentResults.best_sorted.sorted_file))) || null;
            if (!file) {
                alert('Selecciona un CSV o usa el del pipeline.');
                return;
            }
            const limit = parseInt(document.getElementById('cooc-limit').value) || 120;
            const minlen = parseInt(document.getElementById('cooc-minlen').value) || 3;
            const mindf = parseInt(document.getElementById('cooc-mindf').value) || 1;
            const useConcepts = document.getElementById('cooc-use-concepts').checked;
            setSectionProgress('cooc', true, 12, 'Construyendo grafo de coocurrencia…', 'Extrayendo términos y co-ocurrencias');
            const img = document.getElementById('cooc-img'); if (img) img.src = '';
            pywebview.api.analyze_cooccurrence_network(file, limit, mindf, minlen, null, useConcepts).then(resp => {
                if (!resp || !resp.success) {
                    document.getElementById('cooc-degrees').innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${((resp&&resp.message)||'Error construyendo el grafo').replace(/</g,'&lt;')}</span></div>`;
                    setSectionProgress('cooc', true, 100, 'Error en coocurrencia', 'Revisa parámetros o el archivo');
                    setTimeout(() => setSectionProgress('cooc', false, 0, 'Esperando...', ''), 900);
                    return;
                }
                renderCooccurrenceResults(resp.results);
                // Guardar para openFile
                currentResults.cooccurrence = resp.results;
                setSectionProgress('cooc', true, 100, 'Completado', 'Grafo generado');
                setTimeout(() => setSectionProgress('cooc', false, 0, 'Esperando...', ''), 800);
            }).catch(err => {
                document.getElementById('cooc-degrees').innerHTML = `<div class="alert alert-warning"><span>⚠️</span><span>${String(err).replace(/</g,'&lt;')}</span></div>`;
                setSectionProgress('cooc', true, 100, 'Error en coocurrencia', 'Consulta la consola para más detalles');
                setTimeout(() => setSectionProgress('cooc', false, 0, 'Esperando...', ''), 1000);
            });
        }

        function renderCooccurrenceResults(data) {
            // Stats
            const n = document.getElementById('cooc-nodes'); if (n) n.textContent = data.node_count || (data.nodes? data.nodes.length: 0) || 0;
            const e = document.getElementById('cooc-edges'); if (e) e.textContent = data.edge_count || (data.edges? data.edges.length: 0) || 0;
            const c = document.getElementById('cooc-comps'); if (c) c.textContent = data.component_count || (data.components? data.components.length: 0) || 0;
            // Imagen
            const img = document.getElementById('cooc-img');
            if (img) {
                if (data.graph_base64) img.src = 'data:image/png;base64,' + data.graph_base64; else img.src = '';
            }
            // Top grados
            const degreesDiv = document.getElementById('cooc-degrees');
            if (degreesDiv) {
                const degMap = {};
                (data.edges||[]).forEach(e => { degMap[e.source] = (degMap[e.source]||0)+1; degMap[e.target] = (degMap[e.target]||0)+1; });
                const degList = Object.entries(degMap).sort((a,b)=>b[1]-a[1]).slice(0,30);
                if (!degList.length) {
                    degreesDiv.innerHTML = '<span style="color: var(--text-muted)">Sin datos</span>';
                } else {
                    const frag = document.createDocumentFragment();
                    degList.forEach(([term,deg]) => {
                        const d = document.createElement('div');
                        d.style.padding='6px 8px'; d.style.borderBottom='1px solid var(--border)';
                        d.innerHTML = `<strong>${String(term).replace(/</g,'&lt;')}</strong> · grado=${deg}`;
                        frag.appendChild(d);
                    });
                    degreesDiv.innerHTML=''; degreesDiv.appendChild(frag);
                }
            }
            // Componentes
            const compsDiv = document.getElementById('cooc-components');
            if (compsDiv) {
                const comps = data.components || [];
                if (!comps.length) {
                    compsDiv.innerHTML = '<span style="color: var(--text-muted)">Sin componentes</span>';
                } else {
                    const frag = document.createDocumentFragment();
                    comps.forEach((comp, idx) => {
                        const d = document.createElement('div');
                        d.style.padding='6px 8px'; d.style.borderBottom='1px solid var(--border)';
                        d.innerHTML = `<strong>#${idx+1}</strong> · tamaño=${comp.length} · ${comp.join(', ').replace(/</g,'&lt;')}`;
                        frag.appendChild(d);
                    });
                    compsDiv.innerHTML=''; compsDiv.appendChild(frag);
                }
            }
        }
    </script>
</body>
</html>